{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "^(Grep|Read)$",
        "hooks": [ { "type": "command", "command": "/etc/claude-code/hooks/codegraph_first_gate.py" } ]
      },
      {
        "hooks": [ { "type": "command", "command": "/etc/claude-code/hooks/codex_delegation_surface.py" } ]
      }
    ],
    "SubagentStop": [
      { "hooks": [ { "type": "command", "command": "/etc/claude-code/hooks/codex_delegation_surface.py", "asyncRewake": true } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "/etc/claude-code/hooks/codex_delegation_surface.py" } ] }
    ]
  }
}
