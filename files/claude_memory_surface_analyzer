        p = os.path.join(tempfile.mkdtemp(), "t.jsonl")
        with open(p, "w", encoding="utf-8") as f:
            f.write('{"type": "user", "message": {"content": "ok"}}\n')
            f.write("{broken json\n")
        entries, corrupt = _load_transcript(p)
        assert entries is not None
        self.assertEqual(len(entries), 1)
        self.assertTrue(corrupt)


class PathSafetyTest(unittest.TestCase):
    def setUp(self):
        import tempfile
        from unittest import mock

        self.tmp = tempfile.mkdtemp()
        self.fake_live = os.path.join(self.tmp, "live", "memory_index.sqlite3")
        os.makedirs(os.path.dirname(self.fake_live))
        sqlite3.connect(self.fake_live).close()
        self.root = os.path.join(self.tmp, "analyzer")
        os.makedirs(self.root)
        mod = sys.modules[__name__]
        for name, val in (
            ("LIVE_DB_PATH", self.fake_live),
            ("ALLOWED_OUTPUT_ROOTS", (self.root,)),
        ):
            patcher = mock.patch.object(mod, name, val)
            patcher.start()
            self.addCleanup(patcher.stop)

    def test_rejects_live_path_and_outside_root(self):
        with self.assertRaises(RuntimeError):
            _assert_scratch_path(self.fake_live)
        with self.assertRaises(RuntimeError):
            _assert_scratch_path(os.path.join(self.tmp, "elsewhere.sqlite3"))

    def test_rejects_symlink_alias_of_live(self):
        link = os.path.join(self.root, "alias.sqlite3")
        os.symlink(self.fake_live, link)
        with self.assertRaises(RuntimeError):
            _assert_scratch_path(link)

    def test_rejects_hardlink_alias_of_live(self):
        hard = os.path.join(self.root, "hard.sqlite3")
        os.link(self.fake_live, hard)
        with self.assertRaises(RuntimeError):
            _assert_scratch_path(hard)

    def test_allows_fresh_path_under_root(self):
        _assert_scratch_path(os.path.join(self.root, "run1", "db.sqlite3"))

    def test_run_dir_is_exclusive(self):
        out = os.path.join(self.root, "runX")
        self.assertEqual(_create_run_dir(out), out)
        with self.assertRaises(FileExistsError):
            _create_run_dir(out)

    def test_existing_run_dir_rejects_symlink(self):
        real = os.path.join(self.root, "runReal")
        os.makedirs(real)
        link = os.path.join(self.root, "runLink")
        os.symlink(real, link)
        with self.assertRaises(RuntimeError):
            _existing_run_dir(link)
        self.assertEqual(_existing_run_dir(real), real)

    def test_open_out_refuses_symlink_target(self):
        target = os.path.join(self.root, "target.json")
        open(target, "w").close()
        link = os.path.join(self.root, "alias.json")
        os.symlink(target, link)
        with self.assertRaises(OSError):
            _write_jsonl(link, [{"a": 1}])

    def test_clone_db_fails_loudly_on_bad_source(self):
        bad = os.path.join(self.root, "garbage.sqlite3")
        with open(bad, "wb") as f:
            f.write(b"this is not a sqlite database at all" * 10)
        with self.assertRaises(RuntimeError):
            _clone_db(bad, os.path.join(self.root, "out.sqlite3"))

    def test_clone_db_leaves_live_unchanged_and_includes_wal(self):
        import hashlib

        wcon = sqlite3.connect(self.fake_live)
        wcon.execute("PRAGMA journal_mode = WAL")
        wcon.execute("CREATE TABLE t (v TEXT)")
        wcon.execute("INSERT INTO t VALUES ('in-wal')")
        wcon.commit()  # committed but not checkpointed while wcon stays open
        st_before = os.stat(self.fake_live)
        digest_before = hashlib.sha256(open(self.fake_live, "rb").read()).hexdigest()
        dst = os.path.join(self.root, "clone.sqlite3")
        _clone_db(self.fake_live, dst)
        rcon = sqlite3.connect(dst)
        self.assertEqual(rcon.execute("SELECT v FROM t").fetchone()[0], "in-wal")
        rcon.close()
        # Invariance checked while wcon is open: its own close-checkpoint is out of scope.
        st_after = os.stat(self.fake_live)
        self.assertEqual(
            (st_before.st_ino, st_before.st_size, st_before.st_mtime_ns),
            (st_after.st_ino, st_after.st_size, st_after.st_mtime_ns),
        )
        self.assertEqual(
            digest_before, hashlib.sha256(open(self.fake_live, "rb").read()).hexdigest()
        )
        wcon.close()


