class QueryReconstructionTest(unittest.TestCase):
    def test_turn_candidates_ups_and_stop(self):
        entries = [
            {"type": "user", "message": {"content": "first prompt"}},
            {
                "type": "assistant",
                "message": {"content": [{"type": "text", "text": "reply one"}]},
            },
            {"type": "user", "message": {"content": "second prompt"}},
            {
                "type": "assistant",
                "message": {"content": [{"type": "text", "text": "reply two"}]},
            },
            {
                "type": "assistant",
                "message": {"content": [{"type": "text", "text": "more"}]},
            },
        ]
        cands = _turn_candidates(entries)
        self.assertIn(("UPS", "first prompt", 0), cands)
        self.assertIn(("Stop", "reply one", 0), cands)
        self.assertIn(("UPS", "second prompt", 2), cands)
        self.assertIn(("Stop", "reply two\nmore", 2), cands)

    def test_reconstruct_prefix_match_self_verifies(self):
        cands = [("UPS", "hello world " * 30, 0)]
        excerpt = cands[0][1][:QUERY_EXCERPT_LEN]
        source, text = _reconstruct(cands, excerpt)
        self.assertEqual(source, "UPS")
        self.assertEqual(text, cands[0][1])

    def test_reconstruct_no_match(self):
        cands = [("UPS", "abc", 0)]
        self.assertEqual(_reconstruct(cands, "xyz"), (None, None))


