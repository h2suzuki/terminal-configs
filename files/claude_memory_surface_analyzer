        self.tmp = tempfile.mkdtemp()
        self.run_dir = os.path.join(self.tmp, "run")
        os.makedirs(self.run_dir)
        patcher = mock.patch.object(
            sys.modules[__name__], "ALLOWED_OUTPUT_ROOTS", (self.tmp,)
        )
        patcher.start()
        self.addCleanup(patcher.stop)
        _write_jsonl(
            os.path.join(self.run_dir, "events.jsonl"),
            [
                {
                    "id": 1,
                    "reconstructed": True,
                    "ambiguous": False,
                    "transcript_missing": False,
                    "transcript_corrupt": False,
                },
                {
                    "id": 2,
                    "reconstructed": True,
                    "ambiguous": False,
                    "transcript_missing": False,
                    "transcript_corrupt": False,
                },
                {
                    "id": 3,
                    "reconstructed": False,
                    "ambiguous": True,
                    "transcript_missing": False,
                    "transcript_corrupt": False,
                },
                # transcript file gone: excluded from the existing-transcript denominator
                {
                    "id": 4,
                    "reconstructed": False,
                    "ambiguous": False,
                    "transcript_missing": True,
                    "transcript_corrupt": False,
                },
            ],
        )
        _write_jsonl(
            os.path.join(self.run_dir, "rescored.jsonl"),
            [
                # target entry: r0 kill (counts toward gate)
                {
                    "id": 1,
                    "file_path": "/m/target.md",
                    "relevance": 0,
                    "reconstructed": True,
                    "fired_base": True,
                    "fired_cand": False,
                    "score_base": 0.6,
                    "score_cand": None,
                    "picks_base": ["/m/target.md"],
                    "picks_cand": ["/m/other.md"],
                    "new_entries": ["/m/other.md"],
                    "lost_entries": ["/m/target.md"],
                },
                # non-target entry: r2 kill (must NOT count toward gate)
                {
                    "id": 2,
                    "file_path": "/m/unrelated.md",
                    "relevance": 2,
                    "reconstructed": True,
                    "fired_base": True,
                    "fired_cand": False,
                    "score_base": 0.7,
                    "score_cand": None,
                    "picks_base": ["/m/unrelated.md"],
                    "picks_cand": [],
                    "new_entries": [],
                    "lost_entries": ["/m/unrelated.md"],
                },
                {
                    "id": 3,
                    "file_path": "/m/target.md",
                    "relevance": 2,
                    "reconstructed": False,
                    "fired_base": True,
                    "fired_cand": True,
                    "score_base": 0.62,
                    "score_cand": 0.61,
                    "picks_base": ["/m/target.md"],
                    "picks_cand": ["/m/target.md"],
                    "new_entries": [],
                    "lost_entries": [],
                },
            ],
        )

    def test_gate_counts_only_target_entries(self):
        r = _build_report(self.run_dir, ["target.md"])
        gate = r["gate"]
        assert gate is not None
        self.assertEqual(gate["entries"], ["/m/target.md"])
        self.assertEqual(gate["killed_r0"], 1)
        self.assertEqual(gate["max_killed_r2"], 0)  # unrelated.md's r2 kill excluded
        self.assertEqual(r["killed_all"], {"r0": 1, "r1": 0, "r2": 1, "unlabeled": 0})

    def test_gate_absent_without_gate_entries(self):
        self.assertIsNone(_build_report(self.run_dir, None)["gate"])

    def test_reconstruction_rate_existing_excludes_missing_transcripts(self):
        r = _build_report(self.run_dir, None)
        self.assertEqual(r["n_events"], 4)
        self.assertEqual(r["n_transcript_missing"], 1)
        self.assertEqual(r["reconstruction_rate"], 0.5)  # 2/4 raw
        self.assertAlmostEqual(r["reconstruction_rate_existing"], 2 / 3)  # 2/(4-1)

    def test_new_fires_and_pick_changes(self):
        r = _build_report(self.run_dir, None)
        self.assertEqual(r["new_fires_by_entry"], {"/m/other.md": [1]})
        self.assertEqual(r["n_pick_changes"], 2)

    def test_strata_mark_cand_dropped(self):
        r = _build_report(self.run_dir, None)
        s = next(
            s
            for s in r["strata"]
            if s["entry"] == "/m/target.md"
            and s["relevance"] == 0
            and s["reconstructed"]
        )
        self.assertEqual((s["killed"], s["n_cand_dropped"]), (1, 1))
        s2 = next(
            s for s in r["strata"] if s["relevance"] == 2 and not s["reconstructed"]
        )
        self.assertAlmostEqual(s2["score_delta_avg"], -0.01)


@unittest.skipUnless(os.path.exists(_REPO_HOOK_PATH), "repo hook module not found")
class EndToEndTest(unittest.TestCase):
    def setUp(self):
        import tempfile
        from unittest import mock

        self.tmp = tempfile.mkdtemp()
        self.hook = _load_hook_module(_REPO_HOOK_PATH)
        self.fake_live = os.path.join(self.tmp, "live", "fake_live.sqlite3")
        os.makedirs(os.path.dirname(self.fake_live))
        self.root = os.path.join(self.tmp, "analyzer")
        os.makedirs(self.root)
        self.run_dir = os.path.join(self.root, "run")
        self.mem_dir = os.path.join(self.tmp, "mem")
        os.makedirs(self.mem_dir)
        mod = sys.modules[__name__]
        for name, val in (
            ("LIVE_DB_PATH", self.fake_live),
            ("ALLOWED_OUTPUT_ROOTS", (self.root,)),
            ("PROJECTS_DIR", os.path.join(self.tmp, "projects")),
        ):
            patcher = mock.patch.object(mod, name, val)
            patcher.start()
            self.addCleanup(patcher.stop)
        self.entry_path = os.path.join(self.mem_dir, "feedback_test.md")
        with open(self.entry_path, "w", encoding="utf-8") as f:
            f.write(
                "---\n---\nreminder: committed 前に diff を確認する\nkeywords: uncommitted, diff, commit\n"
            )
        # Fixture seeding writes the FAKE live DB directly (deliberately bypasses scratch asserts).
        prev = self.hook.DB_PATH
        self.hook.DB_PATH = self.fake_live  # ty: ignore[unresolved-attribute]
        try:
            con = self.hook._connect()
        finally:
            self.hook.DB_PATH = prev  # ty: ignore[unresolved-attribute]
        assert con is not None
        self.hook._upsert_entry(con, self.entry_path, None)
        self.query_text = "uncommitted の diff を確認してから commit します。" * 3
        con.execute(
            "INSERT INTO inject_log(file_path, project_id, session_id, ts, score, "
            "query_excerpt) VALUES (?, ?, ?, ?, ?, ?)",
            (
                self.entry_path,
                "-tmp-proj",
                "sess-1",
                1_700_000_000.0,
                -5.0,
                self.query_text[:QUERY_EXCERPT_LEN],
            ),
        )
        con.commit()
        con.close()
        transcript_dir = os.path.join(self.tmp, "projects", "-tmp-proj")
        os.makedirs(transcript_dir)
        with open(
            os.path.join(transcript_dir, "sess-1.jsonl"), "w", encoding="utf-8"
        ) as f:
            f.write(
                json.dumps({"type": "user", "message": {"content": self.query_text}})
                + "\n"
            )
            f.write(
                json.dumps(
                    {
                        "type": "assistant",
                        "message": {"content": [{"type": "text", "text": "ack"}]},
                    }
                )
                + "\n"
            )

    def _dataset(self):
        return cmd_dataset(
            argparse.Namespace(
                out=self.run_dir, since=None, labels=None, hook=_REPO_HOOK_PATH
            )
        )

    def _rescore(self, candidate_memory=None, candidate_delete=None):
        return cmd_rescore(
            argparse.Namespace(
                run=self.run_dir,
                candidate_memory=candidate_memory,
                candidate_delete=candidate_delete,
                baseline_db=None,
                hook=_REPO_HOOK_PATH,
            )
        )

    def test_control_run_is_exactly_zero_change(self):
        # Health line: identical clones -> no kills, no new fires, no pick changes.
        self.assertEqual(self._dataset(), 0)
        self.assertEqual(self._rescore(), 0)
        self.assertEqual(
            cmd_report(argparse.Namespace(run=self.run_dir, gate_entries=None)), 0
        )
        report = json.load(open(os.path.join(self.run_dir, "report.json")))
        self.assertEqual(
            report["killed_all"], {"r0": 0, "r1": 0, "r2": 0, "unlabeled": 0}
        )
        self.assertEqual(report["n_new_fire_pairs"], 0)
        self.assertEqual(report["n_pick_changes"], 0)
        self.assertEqual(report["reconstruction_rate"], 1.0)
        self.assertEqual(report["n_transcript_missing"], 0)
        self.assertEqual(report["reconstruction_rate_existing"], 1.0)
        self.assertEqual(report["baseline_refire_rate"], 1.0)
        meta = json.load(open(os.path.join(self.run_dir, "rescore_meta.json")))
        self.assertEqual(meta["baseline_entries"], meta["candidate_entries"])

    def test_keyword_narrowing_kill_detected(self):
        self.assertEqual(self._dataset(), 0)
        with open(self.entry_path, "w", encoding="utf-8") as f:
            f.write("---\n---\nreminder: 全く別の話題\nkeywords: 無関係\n")
        self.assertEqual(self._rescore(candidate_memory=self.mem_dir), 0)
        rescored = _read_jsonl(os.path.join(self.run_dir, "rescored.jsonl"))
        self.assertTrue(rescored[0]["fired_base"])
        self.assertFalse(rescored[0]["fired_cand"])

    def test_delete_scenario_removes_entry(self):
        self.assertEqual(self._dataset(), 0)
        self.assertEqual(self._rescore(candidate_delete=self.entry_path), 0)
        rescored = _read_jsonl(os.path.join(self.run_dir, "rescored.jsonl"))
        self.assertTrue(rescored[0]["fired_base"])
        self.assertFalse(rescored[0]["fired_cand"])
        meta = json.load(open(os.path.join(self.run_dir, "rescore_meta.json")))
        self.assertEqual(meta["n_deletes"], 1)

    def test_scratch_copy_dir_replaces_entry_in_place(self):
        # (a)+(b): same basename, different path -> in-place replacement whose content change kills the fire.
        self.assertEqual(self._dataset(), 0)
        copy_dir = os.path.join(self.tmp, "scratchmem")
        os.makedirs(copy_dir)
        with open(
            os.path.join(copy_dir, "feedback_test.md"), "w", encoding="utf-8"
        ) as f:
            f.write("---\n---\nreminder: 全く別の話題\nkeywords: 無関係\n")
        self.assertEqual(self._rescore(candidate_memory=copy_dir), 0)
        meta = json.load(open(os.path.join(self.run_dir, "rescore_meta.json")))
        self.assertEqual((meta["n_replaced"], meta["n_added"]), (1, 0))
        self.assertEqual(meta["baseline_entries"], meta["candidate_entries"])
        con = sqlite3.connect(os.path.join(self.run_dir, "candidate.sqlite3"))
        fps = [fp for (fp,) in con.execute("SELECT file_path FROM entries_fts")]
        con.close()
        self.assertEqual(fps, [self.entry_path])  # original indexed path preserved
        rescored = _read_jsonl(os.path.join(self.run_dir, "rescored.jsonl"))
        self.assertTrue(rescored[0]["fired_base"])
        self.assertFalse(rescored[0]["fired_cand"])

    def test_same_basename_in_multiple_scopes_requires_project_id(self):
        # (c): user + project scope both hold feedback_test.md -> unqualified candidate errors.
        other_dir = os.path.join(self.tmp, "othermem")
        os.makedirs(other_dir)
        other = os.path.join(other_dir, "feedback_test.md")
        with open(other, "w", encoding="utf-8") as f:
            f.write("---\n---\nreminder: project 側\nkeywords: projscope\n")
        prev = self.hook.DB_PATH
        self.hook.DB_PATH = self.fake_live  # ty: ignore[unresolved-attribute]
        try:
            con = self.hook._connect()
        finally:
            self.hook.DB_PATH = prev  # ty: ignore[unresolved-attribute]
        assert con is not None
        self.hook._upsert_entry(con, other, "-projX")
        con.close()
        self.assertEqual(self._dataset(), 0)
        self.assertEqual(self._rescore(candidate_memory=self.mem_dir), 1)

    def test_delete_of_unindexed_entry_errors(self):
        self.assertEqual(self._dataset(), 0)
        self.assertEqual(
            self._rescore(candidate_delete="/nonexistent/feedback_x.md"), 1
        )

    def test_empty_candidate_dir_errors(self):
        self.assertEqual(self._dataset(), 0)
        empty = os.path.join(self.tmp, "emptymem")
        os.makedirs(empty)
        self.assertEqual(self._rescore(candidate_memory=empty), 1)

    def test_miss_multi_session_hits_are_low_confidence(self):
        self.assertEqual(self._dataset(), 0)
        self.assertEqual(self._rescore(), 0)
        proj = os.path.join(self.tmp, "projects", "-tmp-proj")
        for sid in ("sess-A", "sess-B"):
            with open(os.path.join(proj, sid + ".jsonl"), "w", encoding="utf-8") as f:
                f.write(
                    json.dumps(
                        {
                            "type": "user",
                            "timestamp": "2026-07-02T19:45:00Z",
                            "message": {"content": self.query_text},
                        }
                    )
                    + "\n"
                )
        judgments_path = os.path.join(self.tmp, "judgments.json")
        with open(judgments_path, "w", encoding="utf-8") as f:
            json.dump(
                {
                    "misses": [
                        {
                            "approx_time": "2026-07-02T19:44:28Z - 19:46:35Z",
                            "catalog_file": self.entry_path,
                            "why": "test",
                        }
                    ]
                },
                f,
            )
        self.assertEqual(
            cmd_misses(
                argparse.Namespace(
                    run=self.run_dir, judgments=judgments_path, hook=_REPO_HOOK_PATH
                )
            ),
            0,
        )
        rows = _read_jsonl(os.path.join(self.run_dir, "misses.jsonl"))
        self.assertTrue(rows[0]["fired_cand"])
        self.assertEqual(rows[0]["n_hit_sessions"], 2)
        self.assertTrue(rows[0]["low_confidence"])
        self.assertTrue(all(h["ts"] and h["session"] for h in rows[0]["hits"]))

    def test_upsert_respects_project_id(self):
        self.assertEqual(self._dataset(), 0)
        proj_dir = os.path.join(self.tmp, "projmem")
        os.makedirs(proj_dir)
        with open(
            os.path.join(proj_dir, "feedback_proj.md"), "w", encoding="utf-8"
        ) as f:
            f.write("---\n---\nreminder: project entry\nkeywords: projonly\n")
        self.assertEqual(self._rescore(candidate_memory=f"{proj_dir}=-some-proj"), 0)
        con = sqlite3.connect(os.path.join(self.run_dir, "candidate.sqlite3"))
        rows = con.execute("SELECT file_path, project_id FROM entries_fts").fetchall()
        con.close()
        pids = [pid for fp, pid in rows if fp.endswith("feedback_proj.md")]
        self.assertEqual(pids, ["-some-proj"])


