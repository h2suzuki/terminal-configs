                "message": {"content": [{"type": "text", "text": "more"}]},
            },
        ]
        cands = _turn_candidates(entries)
        self.assertIn(("UPS", "first prompt", 0), cands)
        self.assertIn(("Stop", "reply one", 0), cands)
        self.assertIn(("UPS", "second prompt", 2), cands)
