        source, text, n, ambiguous = _reconstruct(cands, excerpt)
        self.assertEqual((source, text, n, ambiguous), ("UPS", cands[0][1], 1, False))

    def test_reconstruct_duplicate_identical_text_is_unambiguous(self):
