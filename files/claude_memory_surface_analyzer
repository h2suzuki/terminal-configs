        source, text, n, ambiguous = _reconstruct(cands, "same short prompt")
        self.assertEqual(
            (source, text, n, ambiguous), ("UPS", "same short prompt", 2, False)
        )

    def test_reconstruct_distinct_texts_same_prefix_is_ambiguous(self):
        base = "x" * QUERY_EXCERPT_LEN
        cands = [("Stop", base + " tail-A", 0), ("Stop", base + " tail-B", 2)]
        source, text, n, ambiguous = _reconstruct(cands, base)
        self.assertEqual((source, text, ambiguous), (None, None, True))
        self.assertEqual(n, 2)

    def test_reconstruct_no_match(self):
