HOME = os.path.expanduser("~")
LIVE_DB_PATH = "/var/lib/claude-rag-memory/memory_index.sqlite3"
RUN_ROOT = "/var/lib/claude-rag-memory/analyzer"
# All scratch/output writes must land under these roots (tests patch this).
ALLOWED_OUTPUT_ROOTS: tuple[str, ...] = (RUN_ROOT,)
DEFAULT_HOOK_PATH = os.path.join(HOME, ".claude", "hooks", "memory_surface.py")
PROJECTS_DIR = os.path.join(HOME, ".claude", "projects")
QUERY_EXCERPT_LEN = 200
MISS_WINDOW_SECONDS = 120
KILLED_R0_TARGET = 15
KILLED_R0_DENOM = 34
KILLED_R2_MAX_PER_ENTRY = 1


def _iso_to_epoch(s: str | None) -> float | None:
    """ISO8601 -> epoch; naive (timezone-less) inputs are rejected as None."""
    if not s or not isinstance(s, str):
        return None
    try:
        dt = datetime.fromisoformat(s.replace("Z", "+00:00"))
    except ValueError:
        return None
    if dt.tzinfo is None:
        return None
    return dt.timestamp()


def _utc_now_iso() -> str:
    return time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime())


def _load_hook_module(path: str) -> types.ModuleType:
    spec = importlib.util.spec_from_file_location("memory_surface_under_test", path)
    if spec is None or spec.loader is None:
        raise RuntimeError("cannot load hook module: " + path)
    mod = importlib.util.module_from_spec(spec)
    spec.loader.exec_module(mod)
    return mod


# --- output path safety (live DB write-zero guarantee) ---


def _under_allowed_root(path: str) -> bool:
    rp = os.path.realpath(path)
    for root in ALLOWED_OUTPUT_ROOTS:
        rr = os.path.realpath(root)
        if rp == rr or rp.startswith(rr + os.sep):
            return True
    return False


def _assert_scratch_path(path: str) -> None:
    """Reject live-DB aliases (realpath / symlink / hardlink) and paths outside allowed roots."""
    rp = os.path.realpath(path)
    if rp == os.path.realpath(LIVE_DB_PATH):
        raise RuntimeError("refusing to touch live DB: " + path)
    if os.path.islink(path):
        raise RuntimeError("refusing symlinked output path: " + path)
    if (
        os.path.exists(rp)
        and os.path.exists(LIVE_DB_PATH)
        and os.path.samefile(rp, LIVE_DB_PATH)
    ):
        raise RuntimeError("refusing hardlink alias of live DB: " + path)
    if not _under_allowed_root(path):
        raise RuntimeError(
            "output outside allowed roots %s: %s" % (ALLOWED_OUTPUT_ROOTS, path)
        )


def _create_run_dir(out: str | None) -> str:
    """Exclusive new run dir under an allowed root; auto-named with a random suffix when out is None."""
    if out is not None:
        if os.path.islink(out) or not _under_allowed_root(out):
            raise RuntimeError("run dir outside allowed roots or symlinked: " + out)
        os.makedirs(out, exist_ok=False)
        return out
    for _ in range(8):
        name = "%s-%s" % (
            time.strftime("%Y%m%dT%H%M%SZ", time.gmtime()),
            os.urandom(3).hex(),
        )
        path = os.path.join(RUN_ROOT, name)
        try:
            os.makedirs(path, exist_ok=False)
        except FileExistsError:
            continue
        return path
    raise RuntimeError("run dir collision under " + RUN_ROOT)


def _existing_run_dir(path: str) -> str:
    if os.path.islink(path) or not os.path.isdir(path) or not _under_allowed_root(path):
        raise RuntimeError(
            "run dir missing, symlinked, or outside allowed roots: " + path
        )
    return path


def _clone_db(src: str, dst: str) -> None:
    """WAL-consistent clone via the sqlite backup API (read-only source); fails loudly, no silent copy fallback."""
    _assert_scratch_path(dst)
    if not os.path.exists(src):
        sqlite3.connect(dst).close()
        return
    try:
        scon = sqlite3.connect("file:%s?mode=ro" % src, uri=True, timeout=5.0)
        try:
            dcon = sqlite3.connect(dst)
            try:
                scon.backup(dcon)
            finally:
                dcon.close()
        finally:
            scon.close()
    except sqlite3.Error as e:
        raise RuntimeError("ro backup of %s failed: %s" % (src, e)) from e


def _open_scratch_con(hook_mod: types.ModuleType, path: str) -> sqlite3.Connection:
    """Open path via the hook's own _connect() (schema parity), scratch-asserted, DB_PATH restored."""
    _assert_scratch_path(path)
    prev = hook_mod.DB_PATH
    hook_mod.DB_PATH = path  # ty: ignore[unresolved-attribute]
    try:
        con = hook_mod._connect()
    finally:
        hook_mod.DB_PATH = prev  # ty: ignore[unresolved-attribute]
    if con is None:
        raise RuntimeError("failed to open scratch db: " + path)
    return con


def _read_jsonl(path: str) -> list[dict]:
    out = []
    with open(path, encoding="utf-8") as f:
        for line in f:
            line = line.strip()
            if line:
                out.append(json.loads(line))
    return out


def _open_out(path: str):
    """Symlink-refusing output writer (O_NOFOLLOW) for run-dir artifacts."""
    fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC | os.O_NOFOLLOW, 0o644)
    return os.fdopen(fd, "w", encoding="utf-8")


def _write_jsonl(path: str, rows: list[dict]) -> None:
    with _open_out(path) as f:
        for row in rows:
            f.write(json.dumps(row, ensure_ascii=False) + "\n")


def _write_json(path: str, obj: dict) -> None:
    with _open_out(path) as f:
        json.dump(obj, f, ensure_ascii=False, indent=2)


def _write_text(path: str, text: str) -> None:
    with _open_out(path) as f:
        f.write(text)


# --- transcript / query reconstruction (§B-1) ---


def _transcript_path(project_id: str, session_id: str) -> str:
    return os.path.join(PROJECTS_DIR, project_id, session_id + ".jsonl")


def _load_transcript(path: str) -> tuple[list[dict] | None, bool]:
    """(entries, corrupt) — corrupt marks silently dropped undecodable lines (boundary risk)."""
    entries: list[dict] = []
    corrupt = False
    try:
        with open(path, encoding="utf-8") as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entries.append(json.loads(line))
                except json.JSONDecodeError:
                    corrupt = True
    except OSError:
        return None, False
    return entries, corrupt


def _is_prompt(obj: dict) -> bool:
    msg = obj.get("message", {})
    return (
        obj.get("type") == "user"
        and isinstance(msg, dict)
        and isinstance(msg.get("content"), str)
    )


def _stop_text(entries: list[dict], start: int, end: int) -> str:
    """Exact replica of stop_checks._current_turn text join (empty text blocks kept)."""
    parts: list[str] = []
    for obj in entries[start:end]:
        if obj.get("type") != "assistant":
            continue
        msg = obj.get("message", {})
        content = msg.get("content") if isinstance(msg, dict) else None
        if not isinstance(content, list):
            continue
        for block in content:
            if isinstance(block, dict) and block.get("type") == "text":
                parts.append(str(block.get("text", "")))
    return "\n".join(parts)


def _turn_candidates(entries: list[dict]) -> list[tuple[str, str, int]]:
    """(source, text, boundary_index) per prompt boundary; Stop `last_assistant_message` concat is payload-only and NOT reproducible here."""
    boundaries = [i for i, e in enumerate(entries) if _is_prompt(e)]
    out: list[tuple[str, str, int]] = []
    for bi, idx in enumerate(boundaries):
        out.append(("UPS", entries[idx]["message"]["content"], idx))
        end = boundaries[bi + 1] if bi + 1 < len(boundaries) else len(entries)
        stop_text = _stop_text(entries, idx + 1, end)
        if stop_text:
            out.append(("Stop", stop_text, idx))
    return out


def _reconstruct(
    candidates: list[tuple[str, str, int]], excerpt: str
) -> tuple[str | None, str | None, int, bool]:
    """(source, text, n_matches, ambiguous): unique full-text prefix match reconstructs; 0 or >1 distinct texts do not."""
    matches = [(s, t) for s, t, _i in candidates if t[:QUERY_EXCERPT_LEN] == excerpt]
    texts = {t for _s, t in matches}
    # Design decision: multiple prefix matches with the SAME full text are one unique reconstruction.
    if len(texts) == 1:
        sources = {s for s, _t in matches}
        source = next(iter(sources)) if len(sources) == 1 else None
        return source, next(iter(texts)), len(matches), False
    return None, None, len(matches), len(texts) > 1


# --- dataset ---


def cmd_dataset(args: argparse.Namespace) -> int:
    since_epoch = _iso_to_epoch(args.since)
    if args.since and since_epoch is None:
        sys.stderr.write("dataset: --since must be ISO8601 with timezone (e.g. ...Z)\n")
        return 2
    run_dir = _create_run_dir(args.out)
    snapshot = os.path.join(run_dir, "live_snapshot.sqlite3")
    _clone_db(LIVE_DB_PATH, snapshot)
    con = sqlite3.connect(snapshot)
    try:
        rows = con.execute(
            "SELECT id, file_path, project_id, session_id, ts, score, query_excerpt "
            "FROM inject_log ORDER BY id"
        ).fetchall()
    finally:
        con.close()
    labels: dict[int, dict] = {}
    if args.labels:
        with open(args.labels, encoding="utf-8") as f:
            raw = json.load(f)
        for ev in raw.get("events", []):
            labels[ev["id"]] = ev
    events = []
    n_recon = n_ambig = 0
    for rid, file_path, project_id, session_id, ts, score, excerpt in rows:
        if since_epoch is not None and (ts is None or ts < since_epoch):
            continue
        label = labels.get(rid, {})
        entries, corrupt = (None, False)
        transcript_missing = True
        if project_id and session_id:
            tpath = _transcript_path(project_id, session_id)
            transcript_missing = not os.path.exists(tpath)
            entries, corrupt = _load_transcript(tpath)
        source, query, reconstructed, n_matches, ambiguous = (
            None,
            excerpt,
            False,
            0,
            False,
        )
        if entries:
            source, full, n_matches, ambiguous = _reconstruct(
                _turn_candidates(entries), excerpt or ""
            )
            if full is not None:
                query, reconstructed = full, True
        n_recon += reconstructed
        n_ambig += ambiguous
        events.append(
            {
                "id": rid,
                "file_path": file_path,
                "project_id": project_id,
                "session_id": session_id,
                "ts": ts,
                "score_orig": score,
                "query_excerpt": excerpt,
                "query": query,
                "reconstructed": reconstructed,
                "ambiguous": ambiguous,
                "n_prefix_matches": n_matches,
                "transcript_missing": transcript_missing,
                "transcript_corrupt": corrupt,
                "source": source or label.get("source"),
                "relevance": label.get("relevance"),
                "influence": label.get("influence"),
                "note": label.get("note"),
            }
        )
    _write_jsonl(os.path.join(run_dir, "events.jsonl"), events)
    manifest = {
        "run_dir": run_dir,
        "live_snapshot": snapshot,
        "hook_path": args.hook or DEFAULT_HOOK_PATH,
        "n_events": len(events),
        "n_reconstructed": n_recon,
        "n_ambiguous": n_ambig,
        "created": _utc_now_iso(),
    }
    _write_json(os.path.join(run_dir, "manifest.json"), manifest)
    rate = (n_recon / len(events)) if events else 0.0
    sys.stderr.write(
        f"dataset: {len(events)} events, reconstructed {n_recon} ({rate:.1%}), "
        f"ambiguous {n_ambig} -> {run_dir}\n"
    )
    return 0


# --- rescore ---


def _parse_specs(s: str | None) -> list[tuple[str, str | None]]:
    """'item[=project_id],...' -> [(item, project_id | None)]."""
    out: list[tuple[str, str | None]] = []
    for tok in (s or "").split(","):
        tok = tok.strip()
        if not tok:
            continue
        item, _, pid = tok.partition("=")
        out.append((item, pid or None))
    return out


def _replace_entry(
    hook: types.ModuleType,
    con: sqlite3.Connection,
    src_md: str,
    dst_path: str,
    project_id: str | None,
) -> None:
    """Replace indexed entry (dst_path, project_id) with content parsed from src_md (SQL mirrors hook._upsert_entry)."""
    parsed = hook._parse_entry(src_md)
    if parsed is None:
        raise RuntimeError("cannot parse candidate entry: " + src_md)
    reminder, keywords, body = parsed
    mtime = os.path.getmtime(src_md)
    con.execute(
        "DELETE FROM entries_fts WHERE file_path = ? "
        "AND coalesce(project_id, '') = coalesce(?, '')",
        (dst_path, project_id),
    )
    con.execute(
        "INSERT INTO entries_fts(file_path, project_id, "
        "reminder, keywords, body, last_modified) VALUES (?, ?, ?, ?, ?, ?)",
        (dst_path, project_id, reminder, keywords, body, mtime),
    )
    con.execute(
        "DELETE FROM entries_vec WHERE file_path = ? "
        "AND coalesce(project_id, '') = coalesce(?, '')",
        (dst_path, project_id),
    )
    model = hook._model_open()
    if model is not None:
        mcon, dim, max_len = model
        try:
            vec = hook._embed(
                mcon, dim, max_len, hook._embed_entry_text(reminder, keywords)
            )
        finally:
            mcon.close()
        if vec is not None:
            con.execute(
                "INSERT INTO entries_vec(file_path, project_id, vec, "
                "last_modified) VALUES (?, ?, ?, ?)",
                (dst_path, project_id, struct.pack("<%de" % dim, *vec), mtime),
            )
    con.commit()


def _apply_candidate_changes(
    hook: types.ModuleType, con: sqlite3.Connection, args: argparse.Namespace
) -> tuple[int, int, int]:
    """Apply upsert/delete specs; any failure raises (no silent partial candidate corpus)."""
    n_replaced = n_added = n_deletes = 0
    by_basename: dict[str, list[tuple[str, str | None]]] = {}
    for fp, epid in con.execute(
        "SELECT file_path, project_id FROM entries_fts"
    ).fetchall():
        by_basename.setdefault(os.path.basename(fp), []).append((fp, epid))
    for d, pid in _parse_specs(args.candidate_memory):
        mds = sorted(glob.glob(os.path.join(d, "*.md")))
        if not mds:
            raise RuntimeError("candidate-memory dir has no *.md: " + d)
        for md in mds:
            base = os.path.basename(md)
            scopes = by_basename.get(base, [])
            if pid is not None:
                scopes = [s for s in scopes if s[1] == pid]
            if len(scopes) > 1:
                raise RuntimeError(
                    "candidate %s matches multiple index scopes %s; qualify with DIR=PROJECT_ID"
                    % (base, sorted({s[1] or "(user)" for s in scopes}))
                )
            if scopes:
                # Replace: keep the indexed file_path so the backtest swaps content, not identity.
                dst_path, dst_pid = scopes[0]
                _replace_entry(hook, con, os.path.abspath(md), dst_path, dst_pid)
                n_replaced += 1
            else:
                abs_md = os.path.abspath(md)
                if hook._upsert_entry(con, abs_md, pid) != 0:
                    raise RuntimeError("upsert failed: %s (project_id=%s)" % (md, pid))
                by_basename.setdefault(base, []).append((abs_md, pid))
                n_added += 1
    for path, pid in _parse_specs(args.candidate_delete):
        abs_path = os.path.abspath(path)
        row = con.execute(
            "SELECT 1 FROM entries_fts WHERE file_path = ? "
            "AND coalesce(project_id, '') = coalesce(?, '')",
            (abs_path, pid),
        ).fetchone()
        if row is None:
            raise RuntimeError(
                "delete target not indexed in this scope: %s (project_id=%s)"
                % (abs_path, pid)
            )
        if hook._delete_entry(con, abs_path, pid) != 0:
            raise RuntimeError("delete failed: %s (project_id=%s)" % (abs_path, pid))
        n_deletes += 1
    return n_replaced, n_added, n_deletes


def _entry_count(path: str) -> int:
    con = sqlite3.connect("file:%s?mode=ro" % path, uri=True)
    try:
        return con.execute("SELECT count(*) FROM entries_fts").fetchone()[0]
    finally:
        con.close()


def cmd_rescore(args: argparse.Namespace) -> int:
    run_dir = _existing_run_dir(args.run)
    with open(os.path.join(run_dir, "manifest.json"), encoding="utf-8") as f:
        manifest = json.load(f)
    hook_path = args.hook or manifest.get("hook_path") or DEFAULT_HOOK_PATH
    hook = _load_hook_module(hook_path)
    baseline_src = args.baseline_db or manifest["live_snapshot"]
    baseline_work = os.path.join(run_dir, "baseline_work.sqlite3")
    candidate_work = os.path.join(run_dir, "candidate.sqlite3")
    _clone_db(baseline_src, baseline_work)
    _clone_db(baseline_src, candidate_work)

    con_cand = _open_scratch_con(hook, candidate_work)
    try:
        n_replaced, n_added, n_deletes = _apply_candidate_changes(hook, con_cand, args)
    except RuntimeError as e:
        sys.stderr.write("rescore: %s\n" % e)
        return 1
    finally:
        con_cand.close()

    events = _read_jsonl(os.path.join(run_dir, "events.jsonl"))
    con_base = _open_scratch_con(hook, baseline_work)
    con_cand = _open_scratch_con(hook, candidate_work)
    out = []
    n_new = 0
    try:
        for ev in events:
            query = ev["query"]
            project_id = ev.get("project_id") or ""
            now = ev.get("ts") or time.time()
            sid = f"bt-{ev['id']}"
            picks_base = hook._surface_core(con_base, query, sid, project_id, now, 2)
            picks_cand = hook._surface_core(con_cand, query, sid, project_id, now, 2)
            fp = ev["file_path"]
            base_paths = [p[0] for p in picks_base]
            cand_paths = [p[0] for p in picks_cand]
            n_new += sum(1 for p in cand_paths if p not in base_paths)
            out.append(
                {
                    "id": ev["id"],
                    "file_path": fp,
                    "relevance": ev.get("relevance"),
                    "influence": ev.get("influence"),
                    "reconstructed": ev.get("reconstructed"),
                    "source": ev.get("source"),
                    "fired_base": fp in base_paths,
                    "fired_cand": fp in cand_paths,
                    "score_base": next((p[2] for p in picks_base if p[0] == fp), None),
                    "score_cand": next((p[2] for p in picks_cand if p[0] == fp), None),
                    "picks_base": base_paths,
                    "picks_cand": cand_paths,
                    "new_entries": [p for p in cand_paths if p not in base_paths],
                    "lost_entries": [p for p in base_paths if p not in cand_paths],
                }
            )
    finally:
        con_base.close()
        con_cand.close()
    _write_jsonl(os.path.join(run_dir, "rescored.jsonl"), out)
    meta = {
        "baseline_entries": _entry_count(baseline_work),
        "candidate_entries": _entry_count(candidate_work),
        "n_replaced": n_replaced,
        "n_added": n_added,
        "n_deletes": n_deletes,
        "created": _utc_now_iso(),
    }
    _write_json(os.path.join(run_dir, "rescore_meta.json"), meta)
    n_fired_base = sum(1 for r in out if r["fired_base"])
    n_killed = sum(1 for r in out if r["fired_base"] and not r["fired_cand"])
    rate = n_fired_base / len(out) if out else 0.0
    sys.stderr.write(
        f"rescore: {len(out)} events, corpus {meta['baseline_entries']}->"
        f"{meta['candidate_entries']} ({n_replaced} replaced, {n_added} added, "
        f"{n_deletes} deletes), "
        f"baseline refire {n_fired_base}/{len(out)} ({rate:.1%}), "
        f"killed {n_killed}, new pick entries {n_new}\n"
    )
    return 0


# --- misses ---


def _parse_approx_range(s: str | None) -> tuple[float | None, float | None]:
    """'ISO - ISO|HH:MM:SSZ' -> (start, end) epochs; time-only end inherits start date, +1d if it crosses midnight."""
    if not s:
        return None, None
    parts = [p.strip() for p in s.split(" - ")]
    if len(parts) == 2:
        start = _iso_to_epoch(parts[0])
        end_str = parts[1]
        if start is not None and "T" not in end_str:
            end_str = parts[0].split("T")[0] + "T" + end_str
        end = _iso_to_epoch(end_str)
        if start is not None and end is not None and end < start:
            end += 86400.0
        return start, end
    ep = _iso_to_epoch(parts[0])
    return ep, ep


def _date_range(lo: float, hi: float) -> set[str]:
    lo_date = datetime.fromtimestamp(lo, tz=timezone.utc).date()
    hi_date = datetime.fromtimestamp(hi, tz=timezone.utc).date()
    out: set[str] = set()
    d = lo_date
    while d <= hi_date:
        out.add(str(d))
        d = date.fromordinal(d.toordinal() + 1)
    return out


def _scan_transcripts(lo: float, hi: float):
    dates = _date_range(lo, hi)
    for path in glob.glob(os.path.join(PROJECTS_DIR, "*", "*.jsonl")):
        try:
            with open(path, encoding="utf-8", errors="ignore") as f:
                content = f.read()
        except OSError:
            continue
        if not any(d in content for d in dates):
            continue
        project_id = os.path.basename(os.path.dirname(path))
        session_id = os.path.basename(path)[: -len(".jsonl")]
        yield path, project_id, session_id


def _entry_epoch_near(entries: list[dict], idx: int) -> float | None:
    for i in range(idx, min(idx + 20, len(entries))):
        ep = _iso_to_epoch(entries[i].get("timestamp"))
        if ep is not None:
            return ep
    return None


def cmd_misses(args: argparse.Namespace) -> int:
    run_dir = _existing_run_dir(args.run)
    with open(os.path.join(run_dir, "manifest.json"), encoding="utf-8") as f:
        manifest = json.load(f)
    hook_path = args.hook or manifest.get("hook_path") or DEFAULT_HOOK_PATH
    hook = _load_hook_module(hook_path)
    candidate_work = os.path.join(run_dir, "candidate.sqlite3")
    if not os.path.exists(candidate_work):
        sys.stderr.write("misses: candidate.sqlite3 not found; run rescore first\n")
        return 1
    with open(args.judgments, encoding="utf-8") as f:
        judgments = json.load(f)
    con = _open_scratch_con(hook, candidate_work)
    out = []
    n_multi = 0
    try:
        for i, m in enumerate(judgments.get("misses", [])):
            catalog_file = m.get("catalog_file")
            start_ep, end_ep = _parse_approx_range(m.get("approx_time"))
            hits: list[dict] = []
            hit_sessions: set[str] = set()
            first_trigger = None
            seq = 0
            if start_ep is not None:
                lo = start_ep - MISS_WINDOW_SECONDS
                hi = (end_ep or start_ep) + MISS_WINDOW_SECONDS
                for tpath, project_id, session_id in _scan_transcripts(lo, hi):
                    entries, _corrupt = _load_transcript(tpath)
                    if not entries:
                        continue
                    for _source, text, idx in _turn_candidates(entries):
                        ts_ep = _entry_epoch_near(entries, idx)
                        if ts_ep is None or not (lo <= ts_ep <= hi):
                            continue
                        seq += 1
                        # Unique session_id per candidate turn: no throttle carry-over between turns.
                        picks = hook._surface_core(
                            con, text, f"bt-miss-{i}-{seq}", project_id, ts_ep, 2
                        )
                        if first_trigger is None:
                            first_trigger = {"session": session_id, "text": text[:400]}
                        hit = next((p for p in picks if p[0] == catalog_file), None)
                        if hit is not None:
                            hit_sessions.add(session_id)
                            hits.append(
                                {
                                    "session": session_id,
                                    "ts": ts_ep,
                                    "score": hit[2],
                                    "trigger_excerpt": text[:400],
                                }
                            )
            if len(hit_sessions) > 1:
                n_multi += 1
            out.append(
                {
                    "index": i,
                    "catalog_file": catalog_file,
                    "approx_time": m.get("approx_time"),
                    "why": m.get("why"),
                    "n_candidate_turns": seq,
                    "first_trigger": first_trigger,
                    "hits": hits,
                    "n_hit_sessions": len(hit_sessions),
                    "fired_cand": bool(hits),
                    "low_confidence": len(hit_sessions) > 1,
                    "score_cand": hits[0]["score"] if hits else None,
                }
            )
    finally:
        con.close()
    _write_jsonl(os.path.join(run_dir, "misses.jsonl"), out)
    n_recovered = sum(1 for r in out if r["fired_cand"])
    sys.stderr.write(
        f"misses: {len(out)} miss events, recovered {n_recovered} "
        f"(multi-session ambiguous: {n_multi})\n"
    )
    return 0


# --- report ---


def _avg(xs: list[float]) -> float | None:
    return sum(xs) / len(xs) if xs else None


def _entry_matches(fp: str, gate_names: set[str]) -> bool:
    return fp in gate_names or os.path.basename(fp) in gate_names


def _build_strata(rescored: list[dict]) -> list[dict]:
    """Per (entry, relevance, reconstructed) stratum over baseline-fired events (§B-3-iii)."""
    strata: dict[tuple, dict] = {}
    for r in rescored:
        if not r["fired_base"]:
            continue
        key = (r["file_path"], r.get("relevance"), bool(r.get("reconstructed")))
        d = strata.setdefault(
            key, {"n": 0, "killed": 0, "retained": 0, "n_cand_dropped": 0, "deltas": []}
        )
        d["n"] += 1
        if r["fired_cand"]:
            d["retained"] += 1
        else:
            d["killed"] += 1
        sb, sc = r.get("score_base"), r.get("score_cand")
        if sc is None:
            d["n_cand_dropped"] += 1  # fell below floor / out of top-2 in candidate
        elif sb is not None:
            d["deltas"].append(sc - sb)
    out = []
    for (fp, rel, recon), d in sorted(
        strata.items(), key=lambda kv: (kv[0][0], str(kv[0][1]))
    ):
        out.append(
            {
                "entry": fp,
                "relevance": rel,
                "reconstructed": recon,
                "n": d["n"],
                "killed": d["killed"],
                "retained": d["retained"],
                "n_cand_dropped": d["n_cand_dropped"],
                "score_delta_avg": _avg(d["deltas"]),
            }
        )
    return out


def _build_report(run_dir: str, gate_entries: list[str] | None) -> dict:
    events = _read_jsonl(os.path.join(run_dir, "events.jsonl"))
    rescored_path = os.path.join(run_dir, "rescored.jsonl")
    rescored = _read_jsonl(rescored_path) if os.path.exists(rescored_path) else []
    misses_path = os.path.join(run_dir, "misses.jsonl")
    misses = _read_jsonl(misses_path) if os.path.exists(misses_path) else []
    meta_path = os.path.join(run_dir, "rescore_meta.json")
    meta = (
        json.load(open(meta_path, encoding="utf-8"))
        if os.path.exists(meta_path)
        else {}
    )

    n_total = len(events)
    n_recon = sum(1 for e in events if e.get("reconstructed"))
    n_missing = sum(1 for e in events if e.get("transcript_missing"))
    measurable = [r for r in rescored if r["fired_base"]]

    per_entry: dict[str, dict] = {}
    for r in measurable:
        d = per_entry.setdefault(
            r["file_path"],
            {
                "killed_r0": 0,
                "killed_r1": 0,
                "killed_r2": 0,
                "killed_unlabeled": 0,
                "retained": 0,
            },
        )
        if r["fired_cand"]:
            d["retained"] += 1
        else:
            key = {0: "killed_r0", 1: "killed_r1", 2: "killed_r2"}.get(
                r.get("relevance"), "killed_unlabeled"
            )
            d[key] += 1

    gate = None
    if gate_entries:
        names = set(gate_entries)
        gated = {fp: d for fp, d in per_entry.items() if _entry_matches(fp, names)}
        killed_r0 = sum(d["killed_r0"] for d in gated.values())
        max_r2 = max((d["killed_r2"] for d in gated.values()), default=0)
        gate = {
            "entries": sorted(gated),
            "killed_r0": killed_r0,
            "max_killed_r2": max_r2,
            "pass": killed_r0 >= KILLED_R0_TARGET and max_r2 <= KILLED_R2_MAX_PER_ENTRY,
        }

    new_fires_by_entry: dict[str, list[int]] = {}
    for r in rescored:
        for fp in r.get("new_entries", []):
            new_fires_by_entry.setdefault(fp, []).append(r["id"])
    unlabeled_new = [
        r for r in rescored if r.get("new_entries") and r.get("relevance") is None
    ]
    n_pick_changes = sum(
        1 for r in rescored if r.get("picks_base") != r.get("picks_cand")
    )

    return {
        "run_dir": run_dir,
        "rescore_meta": meta,
        "n_events": n_total,
        "n_reconstructed": n_recon,
        "reconstruction_rate": n_recon / n_total if n_total else 0.0,
        "n_transcript_missing": n_missing,
        "reconstruction_rate_existing": (
            n_recon / (n_total - n_missing) if n_total > n_missing else None
        ),
        "n_ambiguous": sum(1 for e in events if e.get("ambiguous")),
        "n_transcript_corrupt": sum(1 for e in events if e.get("transcript_corrupt")),
        "n_rescored": len(rescored),
        "n_baseline_fired": len(measurable),
        "baseline_refire_rate": len(measurable) / len(rescored) if rescored else 0.0,
        "n_excluded": len(rescored) - len(measurable),
        "per_entry": per_entry,
        "killed_all": {
            "r0": sum(d["killed_r0"] for d in per_entry.values()),
            "r1": sum(d["killed_r1"] for d in per_entry.values()),
            "r2": sum(d["killed_r2"] for d in per_entry.values()),
            "unlabeled": sum(d["killed_unlabeled"] for d in per_entry.values()),
        },
        "gate": gate,
        "new_fires_by_entry": new_fires_by_entry,
        "n_new_fire_pairs": sum(len(v) for v in new_fires_by_entry.values()),
        "n_unlabeled_new_fires": len(unlabeled_new),
        "n_pick_changes": n_pick_changes,
        "strata": _build_strata(rescored),
        "n_misses": len(misses),
        "n_misses_recovered": sum(1 for m in misses if m.get("fired_cand")),
        "_unlabeled_new_rows": unlabeled_new,
    }


def _render_report_md(r: dict) -> str:
    lines = [
        "# memory-surface analyzer report",
        "",
        f"- reconstruction rate: {r['n_reconstructed']}/{r['n_events']} ({r['reconstruction_rate']:.1%})"
        f" (ambiguous: {r['n_ambiguous']}, corrupt transcripts: {r['n_transcript_corrupt']})",
        f"- reconstruction rate (existing transcripts): {r['n_reconstructed']}/"
        f"{r['n_events'] - r['n_transcript_missing']} "
        + (
            f"({r['reconstruction_rate_existing']:.1%})"
            if r["reconstruction_rate_existing"] is not None
            else "(n/a)"
        )
        + f" — transcript missing: {r['n_transcript_missing']}",
        f"- baseline refire rate: {r['n_baseline_fired']}/{r['n_rescored']} ({r['baseline_refire_rate']:.1%})",
        f"- excluded (baseline never fired): {r['n_excluded']}",
        f"- killed (all entries): r0={r['killed_all']['r0']} r1={r['killed_all']['r1']}"
        f" r2={r['killed_all']['r2']} unlabeled={r['killed_all']['unlabeled']}",
        f"- pick-set changes: {r['n_pick_changes']}, new fire pairs: {r['n_new_fire_pairs']}"
        f" (unlabeled events: {r['n_unlabeled_new_fires']})",
        f"- misses recovered: {r['n_misses_recovered']}/{r['n_misses']}",
    ]
    gate = r.get("gate")
    if gate:
        lines += [
            "",
            "## gate (target entries only)",
            "",
            f"- entries: {', '.join(os.path.basename(e) for e in gate['entries'])}",
            f"- killed_r0: {gate['killed_r0']} (target >= {KILLED_R0_TARGET}/{KILLED_R0_DENOM})",
            f"- max killed_r2: {gate['max_killed_r2']} (target <= {KILLED_R2_MAX_PER_ENTRY})",
            f"- pass: {gate['pass']}",
        ]
    else:
        lines += [
            "",
            "(gate not evaluated — pass --gate-entries with the modified entries)",
        ]
    lines += [
        "",
        "## per-entry killed breakdown (baseline-fired events)",
        "",
        "| entry | killed_r0 | killed_r1 | killed_r2 | killed_unlabeled | retained |",
        "|---|---|---|---|---|---|",
    ]
    for fp, d in sorted(r["per_entry"].items()):
        lines.append(
            f"| {fp} | {d['killed_r0']} | {d['killed_r1']} | {d['killed_r2']}"
            f" | {d['killed_unlabeled']} | {d['retained']} |"
        )
    if r["new_fires_by_entry"]:
        lines += ["", "## new fires (entries entering picks only in candidate)", ""]
        for fp, ids in sorted(r["new_fires_by_entry"].items()):
            lines.append(
                f"- {fp}: {len(ids)} events (ids: {', '.join(map(str, ids[:20]))})"
            )
    lines += [
        "",
        "## strata (entry × relevance × reconstructed, baseline-fired)",
        "",
        "| entry | rel | recon | n | killed | retained | cand_dropped | score_delta_avg |",
        "|---|---|---|---|---|---|---|---|",
    ]
    for s in r["strata"]:
        delta = (
            "n/a" if s["score_delta_avg"] is None else f"{s['score_delta_avg']:+.4f}"
        )
        lines.append(
            f"| {os.path.basename(s['entry'])} | {s['relevance']} | {s['reconstructed']}"
            f" | {s['n']} | {s['killed']} | {s['retained']} | {s['n_cand_dropped']} | {delta} |"
        )
    lines += [
        "",
        "## caveats",
        "",
        "- excerpt-only stratum (reconstructed=False) supports direction only, not absolute scores (§B-3-iii).",
        "- Stop queries cannot replicate the payload-only `last_assistant_message` concat of stop_checks._run.",
        "- cand_dropped = score_cand is None: entry fell below floor or out of top-2 in candidate.",
        "- multiple prefix matches sharing one identical full text count as a unique reconstruction; only distinct texts are ambiguous.",
        "- miss recoveries with n_hit_sessions > 1 are flagged low_confidence (possible cross-session misattribution).",
        "",
    ]
    return "\n".join(lines)


def cmd_report(args: argparse.Namespace) -> int:
    run_dir = _existing_run_dir(args.run)
    gate_entries = [
        g.strip() for g in (args.gate_entries or "").split(",") if g.strip()
    ]
    report = _build_report(run_dir, gate_entries or None)
    unlabeled = report.pop("_unlabeled_new_rows")
    _write_json(os.path.join(run_dir, "report.json"), report)
    _write_text(os.path.join(run_dir, "report.md"), _render_report_md(report))
    if unlabeled:
        _write_jsonl(os.path.join(run_dir, "unlabeled.jsonl"), unlabeled)
    gate = report.get("gate")
    gate_str = (
        f"gate killed_r0={gate['killed_r0']} max_killed_r2={gate['max_killed_r2']} pass={gate['pass']}"
        if gate
        else "gate not evaluated"
    )
    sys.stderr.write(
        f"report: reconstruction {report['reconstruction_rate']:.1%}, "
        f"baseline refire {report['baseline_refire_rate']:.1%}, "
        f"pick_changes={report['n_pick_changes']} new_fire_pairs={report['n_new_fire_pairs']}, "
        f"{gate_str}\n"
    )
    return 0


_EPILOG = """two-stage control/treatment recipe (shared-corpus gate, §B-3):
  1st run (control corpus): dataset --out RUN1; rescore --run RUN1
       --candidate-memory <dirs of entries BOTH sides must share, e.g. un-indexed project entries>
     -> RUN1/candidate.sqlite3 is the shared control corpus.
  2nd run (treatment): dataset --out RUN2; rescore --run RUN2
       --baseline-db RUN1/candidate.sqlite3 --candidate-memory <dir with ONLY keyword edits>
     -> report --run RUN2 --gate-entries <the 5 modified entries>: gate reflects keyword
        changes alone; corpus additions are identical on both sides.
  Sanity: rescore with no --candidate-memory/--candidate-delete is a control run and
  must show killed 0 / new pick entries 0."""


def main() -> int:
    ap = argparse.ArgumentParser(
        prog="claude_memory_surface_analyzer",
        epilog=_EPILOG,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = ap.add_subparsers(dest="cmd", required=True)

    p_ds = sub.add_parser(
        "dataset", help="inject_log -> prefix-verified events.jsonl (§B-1)"
    )
    p_ds.add_argument("--out", help="new run dir under %s (must not exist)" % RUN_ROOT)
    p_ds.add_argument(
        "--since", help="ISO8601 with timezone; keep events at/after this"
    )
    p_ds.add_argument(
        "--labels", help="judgments.json to join relevance/influence/note by id"
    )
    p_ds.add_argument("--hook", help="memory_surface.py path (default: deployed hook)")
    p_ds.set_defaults(func=cmd_dataset)

    p_rs = sub.add_parser("rescore", help="baseline vs candidate rescoring (§B-2)")
    p_rs.add_argument("--run", required=True)
    p_rs.add_argument(
        "--candidate-memory",
        help="DIR[=PROJECT_ID],... entry dirs to upsert (omit for control run)",
    )
    p_rs.add_argument(
        "--candidate-delete", help="PATH[=PROJECT_ID],... entries to delete"
    )
    p_rs.add_argument(
        "--baseline-db", help="baseline DB (default: run's live snapshot)"
    )
    p_rs.add_argument("--hook")
    p_rs.set_defaults(func=cmd_rescore)

    p_ms = sub.add_parser(
        "misses", help="rescore judged misses in time windows (§B-3-ii)"
    )
    p_ms.add_argument("--run", required=True)
    p_ms.add_argument("--judgments", required=True)
    p_ms.add_argument("--hook")
    p_ms.set_defaults(func=cmd_misses)

    p_rp = sub.add_parser("report", help="aggregate §B-3 metrics -> report.md/json")
    p_rp.add_argument("--run", required=True)
    p_rp.add_argument(
        "--gate-entries", help="basenames/paths of modified entries for gate calc"
    )
    p_rp.set_defaults(func=cmd_report)

    args = ap.parse_args()
    return args.func(args)


