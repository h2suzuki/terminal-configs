@unittest.skipUnless(os.path.exists(_REPO_HOOK_PATH), "repo hook module not found")
class EndToEndTest(unittest.TestCase):
    """dataset -> rescore -> report over a fabricated live DB + transcript, live-write-free."""

    def setUp(self):
        import tempfile

        self.tmp = tempfile.mkdtemp()
        self.hook = _load_hook_module(_REPO_HOOK_PATH)
        self.fake_live = os.path.join(self.tmp, "fake_live.sqlite3")
        self.run_dir = os.path.join(self.tmp, "run")
        os.makedirs(self.run_dir)
        self.mem_dir = os.path.join(self.tmp, "mem")
        os.makedirs(self.mem_dir)
        self.entry_path = os.path.join(self.mem_dir, "feedback_test.md")
        with open(self.entry_path, "w", encoding="utf-8") as f:
            f.write(
                "---\n---\nreminder: committed 前に diff を確認する\nkeywords: uncommitted, diff, commit\n"
            )
        con = _open_scratch_con(self.hook, self.fake_live)
        self.hook._upsert_entry(con, self.entry_path, None)
        self.query_text = "uncommitted の diff を確認してから commit します。" * 3
        con.execute(
            "INSERT INTO inject_log(file_path, project_id, session_id, ts, score, "
            "query_excerpt) VALUES (?, ?, ?, ?, ?, ?)",
            (
                self.entry_path,
                "-tmp-proj",
                "sess-1",
                1_700_000_000.0,
                -5.0,
                self.query_text[:QUERY_EXCERPT_LEN],
            ),
        )
        con.commit()
        con.close()

        proj_dir = os.path.join(PROJECTS_DIR, "-tmp-proj-does-not-exist")
        self.proj_dir_patch = (
            proj_dir  # unused directly; transcript path built via mock below
        )

    def test_dataset_rescore_report_roundtrip(self):
        from unittest import mock

        transcript_dir = os.path.join(self.tmp, "projects", "-tmp-proj")
        os.makedirs(transcript_dir)
        transcript_path = os.path.join(transcript_dir, "sess-1.jsonl")
        with open(transcript_path, "w", encoding="utf-8") as f:
            f.write(
                json.dumps({"type": "user", "message": {"content": self.query_text}})
                + "\n"
            )
            f.write(
                json.dumps(
                    {
                        "type": "assistant",
                        "message": {"content": [{"type": "text", "text": "ack"}]},
                    }
                )
                + "\n"
            )

        mod = sys.modules[__name__]
        with (
            mock.patch.object(mod, "LIVE_DB_PATH", self.fake_live),
            mock.patch.object(mod, "PROJECTS_DIR", os.path.join(self.tmp, "projects")),
        ):
            ds_args = argparse.Namespace(
                out=self.run_dir, since=None, labels=None, hook=_REPO_HOOK_PATH
            )
            self.assertEqual(cmd_dataset(ds_args), 0)
            events = _read_jsonl(os.path.join(self.run_dir, "events.jsonl"))
            self.assertEqual(len(events), 1)
            self.assertTrue(events[0]["reconstructed"])
            self.assertEqual(events[0]["query"], self.query_text)

            rs_args = argparse.Namespace(
                run=self.run_dir,
                candidate_memory=self.mem_dir,
                baseline_db=None,
                hook=_REPO_HOOK_PATH,
            )
            self.assertEqual(cmd_rescore(rs_args), 0)
            rescored = _read_jsonl(os.path.join(self.run_dir, "rescored.jsonl"))
            self.assertEqual(len(rescored), 1)
            self.assertTrue(rescored[0]["fired_base"])
            self.assertTrue(rescored[0]["fired_cand"])  # same entry, unchanged keywords

            rp_args = argparse.Namespace(run=self.run_dir)
            self.assertEqual(cmd_report(rp_args), 0)
            report = json.loads(open(os.path.join(self.run_dir, "report.json")).read())
            self.assertEqual(report["n_baseline_fired"], 1)
            self.assertEqual(report["reconstruction_rate"], 1.0)

    def test_rescore_detects_kill_after_keyword_narrowing(self):
        from unittest import mock

        transcript_dir = os.path.join(self.tmp, "projects", "-tmp-proj")
        os.makedirs(transcript_dir, exist_ok=True)
        transcript_path = os.path.join(transcript_dir, "sess-1.jsonl")
        with open(transcript_path, "w", encoding="utf-8") as f:
            f.write(
                json.dumps({"type": "user", "message": {"content": self.query_text}})
                + "\n"
            )

        mod = sys.modules[__name__]
        with (
            mock.patch.object(mod, "LIVE_DB_PATH", self.fake_live),
            mock.patch.object(mod, "PROJECTS_DIR", os.path.join(self.tmp, "projects")),
        ):
            cmd_dataset(
                argparse.Namespace(
                    out=self.run_dir, since=None, labels=None, hook=_REPO_HOOK_PATH
                )
            )
            # candidate dir has an entry at the SAME file_path but unrelated keywords -> should not fire.
            same_path_dir = os.path.dirname(self.entry_path)
            with open(self.entry_path, "w", encoding="utf-8") as f:
                f.write("---\n---\nreminder: 全く別の話題\nkeywords: 無関係\n")
            cmd_rescore(
                argparse.Namespace(
                    run=self.run_dir,
                    candidate_memory=same_path_dir,
                    baseline_db=None,
                    hook=_REPO_HOOK_PATH,
                )
            )
            rescored = _read_jsonl(os.path.join(self.run_dir, "rescored.jsonl"))
            self.assertTrue(rescored[0]["fired_base"])
            self.assertFalse(rescored[0]["fired_cand"])


