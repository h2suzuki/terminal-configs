class VoicevoxSynth:
    """VOICEVOX Core の初期化・モデル読み込み・音声合成をカプセル化する。

    __init__ では VVM のメタデータのみ読み取る (高速)。
    ONNX モデルの実ロードは synthesize() の初回呼び出し時に遅延実行する。
    """

    def __init__(self, onnxruntime: str, dict_dir: Path, device: AccelerationMode,
                 vvm_dir: Path, patterns: list[str]):
        cpu_num_threads = max(multiprocessing.cpu_count(), 2)

        _vprint(f"Onnxruntime.load_once: {onnxruntime}")
        ort = Onnxruntime.load_once(filename=onnxruntime)
        devs = ort.supported_devices()
        _vprint("  supported_devices: " + ", ".join(
            k for k in ("cpu", "cuda", "dml") if getattr(devs, k)
        ))

        _vprint(f"Synthesizer init: device={device}, dict_dir={dict_dir}, "
                f"cpu_num_threads={cpu_num_threads}")
        self._synth = Synthesizer(
            ort,
            OpenJtalk(dict_dir),
            acceleration_mode=device,
            cpu_num_threads=cpu_num_threads,
        )
        _vprint(f"  is_gpu_mode={self._synth.is_gpu_mode}")

        self._vvm_tree = self._scan_model_meta(vvm_dir, patterns)
        _vprint(f"{len(self._vvm_tree)} model(s) scanned")

        self._style_detail: dict[int, tuple[str, str]] = {}
        self._style_to_vvm: dict[int, Path] = {}
        for vvm_path, speakers in self._vvm_tree:
            for sp in speakers:
                for style in sp.styles:
                    self._style_detail[style.id] = (sp.name, style.name)
                    self._style_to_vvm[style.id] = vvm_path

        self._loaded_vvms: set[Path] = set()

    def _scan_model_meta(self, vvm_dir: Path,
                     patterns: list[str]) -> list[tuple[Path, list]]:
        """VVM ファイルのメタデータだけ読み取る (ONNX ロードは行わない)。"""
        # パターンを展開して重複を除く
        seen: set[Path] = set()
        vvm_files: list[Path] = []
        for pat in patterns:
            for p in sorted(vvm_dir.glob(pat)):
                if p not in seen:
                    seen.add(p)
                    vvm_files.append(p)

        _vprint(f"VVM search: dir={vvm_dir}, patterns={patterns}, "
                f"found={len(vvm_files)}")

        if not vvm_files:
            raise FileNotFoundError(
                f"no .vvm files matching {patterns} in {vvm_dir}"
            )

        vvm_tree: list[tuple[Path, list]] = []
        for vvm_path in vvm_files:
            _vprint(f"  scanning meta: {vvm_path.name}")
            with VoiceModelFile.open(vvm_path) as model:
                metas = list(model.metas)
            # ツリー表示用: styles[] を style_id でソートし、話者を安定ソート
            for sp in metas:
                sp.styles = sorted(sp.styles, key=lambda s: s.id)
            metas.sort(key=lambda sp: sp.styles[0].id)
            vvm_tree.append((vvm_path, metas))

        return vvm_tree

    def _ensure_loaded(self, style_id: int) -> None:
        """指定 style_id を含む VVM が未ロードなら ONNX モデルをロードする。"""
        vvm_path = self._style_to_vvm[style_id]
        if vvm_path in self._loaded_vvms:
            return
        _vprint(f"  lazy loading: {vvm_path.name}")
        with VoiceModelFile.open(vvm_path) as model:
            self._synth.load_voice_model(model)
        self._loaded_vvms.add(vvm_path)
        _vprint(f"  loaded: {vvm_path.name}")

    @property
    def min_style_id(self) -> int:
        """読み込み済みモデルの中で最小の style_id を返す。"""
        return min(self._style_detail)

    def list_speakers(self, selected_style_id: int | None = None) -> None:
        """VVM → 話者 → スタイル のツリーを表示する。"""
        if not self._vvm_tree:
            print("no models loaded", file=sys.stderr)
            return

        bold, reset = (BOLD, RESET) if sys.stdout.isatty() else ("", "")

        # 話者名・スタイル名の最大 display width (CJK 全角=2) でアライン
        _dw = lambda s: sum(
            2 if unicodedata.east_asian_width(c) in 'WF' else 1 for c in s)
        max_name_w = max(
            w
            for _, speakers in self._vvm_tree
            for sp in speakers
            for w in [_dw(sp.name) - 2] + [_dw(s.name) for s in sp.styles])

        for vi, (vvm_path, speakers) in enumerate(self._vvm_tree):
            is_last_vvm = vi == len(self._vvm_tree) - 1
            print(vvm_path.name)
            for si, speaker in enumerate(speakers):
                is_last_speaker = si == len(speakers) - 1
                branch_s = "└── " if is_last_speaker else "├── "
                prefix_s = "    " if is_last_speaker else "│   "
                print(f"{branch_s}{speaker.name}")

                for ti, style in enumerate(speaker.styles):
                    is_last_style = ti == len(speaker.styles) - 1
                    branch_t = "└── " if is_last_style else "├── "
                    pad = ' ' * (max_name_w - _dw(style.name))
                    if style.id == selected_style_id:
                        print(f"{bold}{prefix_s}{branch_t}{style.name}{pad}  "
                              f"(style-id: {style.id}) ◀{reset}")
                    else:
                        print(f"{prefix_s}{branch_t}{style.name}{pad}  "
                              f"(style-id: {style.id})")

            if not is_last_vvm:
                print()

    def dump_styles(self, selected_style_id: int | None = None) -> None:
        """スタイル一覧を stderr に出力する。"""
        bold, reset = (BOLD, RESET) if sys.stderr.isatty() else ("", "")
        for vvm_path, speakers in self._vvm_tree:
            for sp in speakers:
                for style in sp.styles:
                    if style.id == selected_style_id:
                        print(f"{bold}  {vvm_path.name}: style-id: {style.id}: "
                              f"{sp.name} ({style.name}) ◀{reset}",
                              file=sys.stderr)
                    else:
                        print(f"  {vvm_path.name}: style-id: {style.id}: "
                              f"{sp.name} ({style.name})", file=sys.stderr)

    def validate_style_id(self, style_id: int) -> str | None:
        """style_id が有効なら None、無効ならエラーメッセージを返す。"""
        if style_id in self._style_detail:
            return None
        lines = [f"style-id {style_id} not found in loaded models. available:"]
        for sid in sorted(self._style_detail):
            sp_name, st_name = self._style_detail[sid]
            lines.append(f"  {sp_name}  {st_name}  (style-id: {sid})")
        return "\n".join(lines)

    def synthesize(self, **opts) -> bytes:
        """テキストを音声合成し、WAV バイナリを返す。"""
        self._ensure_loaded(opts["style_id"])
        speaker, style = self._style_detail.get(opts["style_id"], ("?", "?"))
        _vprint(f'create_audio_query: style-id: {opts["style_id"]} "{speaker} ({style})"')
        audio_query = self._synth.create_audio_query(opts["text"], opts["style_id"])

        audio_query.speed_scale = opts.get("speed", 1.0)
        audio_query.pitch_scale = opts.get("pitch", 0.0)
        audio_query.intonation_scale = opts.get("intonation", 1.0)
        audio_query.volume_scale = opts.get("volume", 1.0)
        if opts.get("pre_silence") is not None:
            audio_query.pre_phoneme_length = opts["pre_silence"]
        if opts.get("post_silence") is not None:
            audio_query.post_phoneme_length = opts["post_silence"]

        _vprint(f"synthesis: { {k: v for k, v in opts.items() if k != 'text'} }")
        wav = self._synth.synthesis(audio_query, opts["style_id"])
        _vprint(f"  synthesis done: {len(wav):,} bytes")
        return wav


# ============================================================
# Command Line 処理
# ============================================================

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="VOICEVOX で音声合成し PulseAudio で再生する",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""\
使用例:
  %(prog)s "こんにちは"                     基本的な読み上げ
  %(prog)s --speed 1.5 "速く読む"          話速変更
  %(prog)s --style-id 1 "ずんだもん"       話者変更
  %(prog)s --vvm 0.vvm --vvm 1.vvm "テスト" 複数モデル読み込み (繰り返し)
  %(prog)s --vvm '[01].vvm' "テスト"       複数モデル読み込み (glob)
  %(prog)s --vvm '*.vvm' --list-speakers   全モデルの話者一覧
  %(prog)s --out out.wav "保存する"        WAV ファイルに保存 (再生なし)
  echo "文章" | %(prog)s                   標準入力から読み上げ
  %(prog)s -v "デバッグ"                   診断情報を表示
  %(prog)s --loopback "ループバック"       distro proxy 経由で再生 (SSH 対応)
"""
    )

    # --- 入力 ---
    parser.add_argument(
        "text", nargs="?", default=None,
        help="読み上げるテキスト (省略時: 標準入力から読み取り)",
    )

    # --- 音声パラメータ ---
    audio = parser.add_argument_group("音声パラメータ")
    audio.add_argument(
        "--style-id", type=int, default=-1,
        metavar="ID",
        help="話者・スタイルの指定 (--list-speakers で確認, 既定値: 最小 ID)",
    )
    audio.add_argument(
        "--speed", type=float, default=1.0,
        metavar="VALUE",
        help="話速 (既定値: 1.0, 大きいほど速い)",
    )
    audio.add_argument(
        "--pitch", type=float, default=0.0,
        metavar="VALUE",
        help="ピッチ (既定値: 0.0)",
    )
    audio.add_argument(
        "--intonation", type=float, default=1.0,
        metavar="VALUE",
        help="抑揚 (既定値: 1.0)",
    )
    audio.add_argument(
        "--volume", type=float, default=1.0,
        metavar="VALUE",
        help="音量 (既定値: 1.0)",
    )
    audio.add_argument(
        "--pre-silence", type=float, default=None,
        metavar="SEC",
        help="発話前の無音 (秒)",
    )
    audio.add_argument(
        "--post-silence", type=float, default=None,
        metavar="SEC",
        help="発話後の無音 (秒)",
    )

    # --- パス設定 ---
    paths = parser.add_argument_group("パス設定")
    paths.add_argument(
        "--cache-dir", type=Path, default=NOT_GIVEN,
        dest="cache_dir", metavar="DIR",
        help="WAV キャッシュを有効にし、指定ディレクトリを使う",
    )
    paths.add_argument(
        "--voicevox-dir", type=Path, default=PREFIX,
        metavar="PREFIX",
        help=f"VOICEVOX Coreディレクトリ (既定値: {PREFIX})",
    )
    paths.add_argument(
        "--onnxruntime", default=None,
        metavar="FILE",
        help="ONNX Runtime (既定値: PREFIX/onnxruntime/lib/" \
             "{Onnxruntime.LIB_VERSIONED_FILENAME})",
    )
    paths.add_argument(
        "--dict-dir", type=Path, default=None,
        metavar="DIR",
        help="Open JTalk辞書ディレクトリ (既定値: PREFIX/dict)",
    )
    paths.add_argument(
        "--vvm-dir", type=Path, default=None,
        metavar="DIR",
        help="VVMモデルディレクトリ (既定値: PREFIX/models/vvms)",
    )
    paths.add_argument(
        "--vvm", type=str, action="append", default=None,
        dest="vmms", metavar="GLOB_PAT",
        help="読み込むVVMファイル名パターン (複数回指定可, 既定値: 0.vvm)",
    )

    # --- デバイス選択 ---
    engine = parser.add_argument_group("デバイス選択")
    engine.add_argument(
        "--device", default="CPU",
        choices=("AUTO", "CPU", "GPU"),
        help="演算デバイス (既定値: CPU)",
    )

    # --- 出力制御 ---
    output = parser.add_argument_group("出力制御")
    output.add_argument(
        "--out", type=Path, default=None,
        dest="outfile", metavar="FILE",
        help="WAV ファイルに保存して終了 (再生なし)",
    )
    output.add_argument(
        "--cache", action="store_true",
        help="WAV キャッシュを有効にする ",
    )
    output.add_argument(
        "--loopback", action="store_true",
        help=f"PULSE_SERVER を tcp:localhost:{PULSE_LOOPBACK_PORT} に固定 "
             "(distro 内 proxy 経由で WSLg direct の不安定性を回避、"
             "SSH port-forward でも利用可能)",
    )
    output.add_argument(
        "--list-speakers", action="store_true",
        help="利用可能な話者スタイルの一覧を表示して終了",
    )
    output.add_argument(
        "--verbose", "-v", action="store_true",
        help="主要な動作の前後で診断情報を表示する",
    )

    return parser


# コマンドライン引数のパース (モジュールロード時に実行)
parser = build_parser()
args = parser.parse_args()


def _die(msg: str) -> None:
    """エラーメッセージを表示して終了する (usage は表示しない)。"""
    print(f"error: {msg}", file=sys.stderr)
    sys.exit(2)


# ============================================================
# メイン処理
# ============================================================

def main() -> None:

    # --- 既定値の解決 (未指定の引数を voicevox_dir から導出) ---
    if not args.onnxruntime:
        args.onnxruntime = str(
            args.voicevox_dir / "onnxruntime" / "lib" / Onnxruntime.LIB_VERSIONED_FILENAME
        )
    if not args.dict_dir:
        args.dict_dir = args.voicevox_dir / "dict" / "open_jtalk_dic_utf_8-1.11"
    if not args.vvm_dir:
        args.vvm_dir = args.voicevox_dir / "models" / "vvms"
    if not args.vmms:
        args.vmms = ["0.vvm"]
    if args.cache_dir is NOT_GIVEN:
        if args.cache:
            # --cache のみ → XDG_CACHE_HOME 配下、なければ ~/.cache/$prog
            if os.environ.get("XDG_CACHE_HOME"):
                args.cache_dir = Path(os.environ["XDG_CACHE_HOME"]) / parser.prog
            else:
                args.cache_dir = Path.home() / ".cache" / parser.prog
        else:
            args.cache_dir = None

    # --- パスの存在チェック ---
    if not Path(args.onnxruntime).exists():
        _die(f"ONNX Runtime not found: {args.onnxruntime}")
    if not args.dict_dir.is_dir():
        _die(f"Open JTalk dict directory not found: {args.dict_dir}")
    if not args.vvm_dir.is_dir():
        _die(f"VVM model directory not found: {args.vvm_dir}")

    # --- 引数・環境の表示 ---
    _vprint("--- args ---")
    _vprint(f"  style-id       = {args.style_id}")
    _vprint(f"  speed          = {args.speed}")
    _vprint(f"  pitch          = {args.pitch}")
    _vprint(f"  intonation     = {args.intonation}")
    _vprint(f"  volume         = {args.volume}")
    _vprint(f"  pre_silence    = {args.pre_silence}")
    _vprint(f"  post_silence   = {args.post_silence}")
    _vprint(f"  device         = {args.device}")
    _vprint(f"  voicevox_dir   = {args.voicevox_dir}")
    _vprint(f"  onnxruntime    = {args.onnxruntime}")
    _vprint(f"  dict_dir       = {args.dict_dir}")
    _vprint(f"  vvm_dir        = {args.vvm_dir}")
    _vprint(f"  vmms           = {args.vmms}")
    _vprint(f"  cache_dir      = {args.cache_dir}")
    _vprint(f"  outfile        = {args.outfile}")
    _vprint(f"  list_speakers  = {args.list_speakers}")
    _vprint(f"  loopback       = {args.loopback}")

    # --- --loopback: PULSE_SERVER を override して distro proxy 経由にする ---
    if args.loopback:
        os.environ["PULSE_SERVER"] = f"tcp:localhost:{PULSE_LOOPBACK_PORT}"

    _vprint("--- env ---")
    _vprint(f"  PULSE_SERVER   = {os.environ.get('PULSE_SERVER', '(unset)')}")
    _vprint(f"  PULSE_COOKIE   = {os.environ.get('PULSE_COOKIE', '(unset)')}")
    _vprint(f"  XDG_RUNTIME_DIR= {os.environ.get('XDG_RUNTIME_DIR', '(unset)')}")
    _vprint(f"  XDG_CACHE_HOME = {os.environ.get('XDG_CACHE_HOME', '(unset)')}")
    _vprint(f"  Python         = {sys.version}")
    _vprint(f"  cpu_count      = {multiprocessing.cpu_count()}")

    # --- 初期化 ---
    synth = VoicevoxSynth(
        args.onnxruntime, args.dict_dir, args.device, args.vvm_dir, args.vmms,
    )

    # --- style-id の解決と検証 ---
    if args.style_id < 0:
        args.style_id = synth.min_style_id
        _vprint(f"style-id resolved to {args.style_id}")
    else:
        err = synth.validate_style_id(args.style_id)
        if err:
            _die(err)

    # --- 話者一覧モード ---
    if args.list_speakers:
        synth.list_speakers(args.style_id)
        return

    # --- スタイル一覧表示 ---
    if args.verbose:
        synth.dump_styles(args.style_id)

    # --- テキスト取得 ---
    if args.text:
        text = args.text.strip()
    else:
        text = sys.stdin.read().strip()
    if not text:
        _die("text is empty")

    if args.verbose:
        _vprint("target text:")
        for line in text.split("\n")[:5]:
            print(f"  {line[:80]}", file=sys.stderr)
        if text.count("\n") >= 5:
            print("  ...", file=sys.stderr)

    # synthesize() と WavCache で共有する合成パラメータ
    synth_opts = dict(
        text=text,
        style_id=args.style_id,
        speed=args.speed,
        pitch=args.pitch,
        intonation=args.intonation,
        volume=args.volume,
        pre_silence=args.pre_silence,
        post_silence=args.post_silence,
    )

    # --- WavCache にある生成済み音声を再利用 ---
    cache = None
    if args.cache_dir:
        try:
            cache = WavCache(args.cache_dir)
        except OSError as e:
            _vprint(f"warning: cache disabled ({e})")

    if cache:
        wav_data = cache.get(synth_opts)
        if wav_data is None:
            # キャッシュになかった → 音声合成
            wav_data = synth.synthesize(**synth_opts)
            cache.put(wav_data, synth_opts)
    else:
        wav_data = synth.synthesize(**synth_opts)

    # --- 出力 ---
    if args.outfile:
        args.outfile.write_bytes(wav_data)
        _vprint(f"saved: {args.outfile}")
    else:
        play_wav_pulse(wav_data)


if __name__ == "__main__":
    main()
