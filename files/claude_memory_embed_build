#!/usr/bin/env python3
"""Build the memory-surface embed model DB (token -> fp16 vector SQLite), stdlib-only.

Downloads the model2vec snapshot (tokenizer.json + model.safetensors) via
urllib, parses the safetensors container by hand, converts fp32 rows to fp16
with struct, and bakes the vocab/meta tables that the memory-surface hook
reads at query time. No third-party packages, no venv.
"""

from __future__ import annotations

import argparse
import json
import mmap
import os
import sqlite3
import struct
import sys
import tempfile
import urllib.request

MODEL_NAME = "minishlab/potion-multilingual-128M"
BASE_URL = f"https://huggingface.co/{MODEL_NAME}/resolve/main/"
MODEL_FILES = ("tokenizer.json", "model.safetensors")
DB_PATH = os.path.expanduser("~/.claude/hooks/state/memory_embed_model.sqlite3")
# Both constants are part of the hook's query contract: longer pieces never
# match real text (bounds Viterbi cost); ids 0/1 = [PAD]/[UNK] are excluded.
MAX_TOKEN_LEN = 24
UNK_ID = 1
HTTP_TIMEOUT = 60
CHUNK = 1 << 20


def already_built() -> bool:
    """True iff a schema-valid model DB exists (meta has dim + max_token_len)."""
    if not os.path.exists(DB_PATH):
        return False
    try:
        con = sqlite3.connect("file:%s?mode=ro" % DB_PATH, uri=True, timeout=2.0)
        meta = dict(con.execute("SELECT key, value FROM meta"))
        con.close()
    except sqlite3.Error:
        return False
    return "dim" in meta and "max_token_len" in meta


def download(url: str, dst: str) -> None:
    req = urllib.request.Request(
        url, headers={"User-Agent": "claude-memory-embed-build"}
    )
    with urllib.request.urlopen(req, timeout=HTTP_TIMEOUT) as r, open(dst, "wb") as w:
        while True:
            chunk = r.read(CHUNK)
            if not chunk:
                break
            w.write(chunk)
    sys.stderr.write(
        f"downloaded {os.path.basename(dst)}: {os.path.getsize(dst):,} bytes\n"
    )


def build(model_dir: str) -> int:
    with open(os.path.join(model_dir, "tokenizer.json"), encoding="utf-8") as f:
        tok = json.load(f)
    if tok.get("model", {}).get("type") != "Unigram":
        sys.stderr.write("unsupported tokenizer type (expected Unigram)\n")
        return 1
    vocab = tok["model"]["vocab"]

    # safetensors container: u64-LE header length, JSON header, then raw tensors.
    with open(os.path.join(model_dir, "model.safetensors"), "rb") as f:
        hlen = struct.unpack("<Q", f.read(8))[0]
        info = json.loads(f.read(hlen)).get("embeddings")
        if not info or info["dtype"] != "F32":
            sys.stderr.write("embeddings tensor missing or not F32\n")
            return 1
        rows, dim = info["shape"]
        start, end = info["data_offsets"]
        if rows != len(vocab) or (end - start) != rows * dim * 4:
            sys.stderr.write(f"vocab/embedding mismatch: {len(vocab)} vs {rows}\n")
            return 1
        mm = mmap.mmap(f.fileno(), 0, access=mmap.ACCESS_READ)
        # .cast uses native order = little-endian on supported hosts; the hook
        # unpacks '<e', so a big-endian host would need explicit byte swapping.
        floats = memoryview(mm)[8 + hlen + start : 8 + hlen + end].cast("f")
        if sys.byteorder != "little":
            sys.stderr.write("big-endian hosts are not supported\n")
            return 1
        pack_row = struct.Struct("<%de" % dim).pack

        tmp = DB_PATH + ".tmp"
        os.makedirs(os.path.dirname(DB_PATH), exist_ok=True)
        if os.path.exists(tmp):
            os.remove(tmp)
        con = sqlite3.connect(tmp)
        try:
            con.execute("PRAGMA journal_mode = OFF")  # bulk build; replaced atomically
            con.execute("CREATE TABLE meta (key TEXT PRIMARY KEY, value TEXT)")
            con.execute(
                "CREATE TABLE vocab (token TEXT PRIMARY KEY, id INTEGER NOT NULL, "
                "score REAL NOT NULL, vec BLOB NOT NULL) WITHOUT ROWID"
            )
            con.executemany(
                "INSERT OR IGNORE INTO vocab VALUES (?, ?, ?, ?)",
                (
                    (t, i, s, pack_row(*floats[i * dim : (i + 1) * dim]))
                    for i, (t, s) in enumerate(vocab)
                    if i > UNK_ID and len(t) <= MAX_TOKEN_LEN
                ),
            )
            con.execute("CREATE INDEX vocab_id ON vocab(id)")
            con.executemany(
                "INSERT INTO meta VALUES (?, ?)",
                [
                    ("dim", str(dim)),
                    ("max_token_len", str(MAX_TOKEN_LEN)),
                    ("source", MODEL_NAME),
                ],
            )
            con.commit()
            n = con.execute("SELECT COUNT(*) FROM vocab").fetchone()[0]
        finally:
            con.close()
            floats.release()  # mmap refuses to close while views are exported
            mm.close()
    os.replace(tmp, DB_PATH)
    sys.stderr.write(
        f"built {DB_PATH}: {n} tokens, dim={dim}, "
        f"{os.path.getsize(DB_PATH) // 1_000_000} MB\n"
    )
    return 0


def main() -> int:
    ap = argparse.ArgumentParser(
        description="Build the memory-surface embed model DB (stdlib-only)"
    )
    ap.add_argument(
        "model_dir", nargs="?", help="local dir with the model files (skips download)"
    )
    ap.add_argument(
        "-f", "--force", action="store_true", help="rebuild even if the DB exists"
    )
    args = ap.parse_args()
    if not args.force and already_built():
        sys.stderr.write(f"{DB_PATH} already built; use --force to rebuild\n")
        return 0
    if args.model_dir:
        return build(args.model_dir)
    with tempfile.TemporaryDirectory(prefix="memory-embed-") as tmp_dir:
        for name in MODEL_FILES:
            try:
                download(BASE_URL + name, os.path.join(tmp_dir, name))
            except OSError as e:
                sys.stderr.write(f"download failed for {name}: {e}\n")
                return 1
        return build(tmp_dir)


if __name__ == "__main__":
    sys.exit(main())
