#!/bin/bash
# voicevox_claude_alerts — voicevox-based audio notifications for Claude Code.
#
# This script has two operating modes:
#
# 1. Hook mode (invoked by Claude Code from settings.json's hooks block):
#    Receives the hook payload on stdin and dispatches to the matching
#    speech path. All audio playback is detached via `setsid -f`, so the
#    harness observes the script return immediately. The script always
#    exits 0 in hook mode.
#
# 2. CLI mode (interactive use):
#    Subcommands `events`, `log`, `say`, `help`. See `help` for details.
#    Useful for listing supported events, inspecting the spoken-log,
#    or smoke-testing voicevox_paplay end-to-end.
#
# Claude Code calling convention
# (verified against docs.claude.com hooks reference, 2026-04-30):
#
#   - The command string from settings.json is run as a shell command.
#     Its first word is the program; anything after is argv. Claude Code
#     does NOT auto-append the event name. We rely on:
#       (a) argv[1] when settings.json supplies it (e.g. ".../alerts Stop"),
#       (b) stdin's `hook_event_name` field as the canonical fallback.
#
#   - stdin = full hook payload as JSON. Fields this script actually reads
#     (the docs list many more, all ignored here):
#       common            session_id, hook_event_name
#       Stop              + last_assistant_message
#       SubagentStop      + last_assistant_message, agent_type
#       SubagentStart     + agent_type
#       Notification      + notification_type, message
#       ConfigChange      + source (user_settings|project_settings|local_settings|policy_settings|skills)
#       CwdChanged        + cwd (common field; the new working directory)
#     For Notification, notification_type ∈ permission_prompt, idle_prompt,
#     auth_success, elicitation_dialog, elicitation_complete,
#     elicitation_response — only the first two are handled below.
#
#   - Exit code semantics:
#       0           Proceed. stdout (if non-empty) is parsed as a JSON
#                   decision; otherwise it is injected as additionalContext.
#       2           Block (PreToolUse / Stop / etc.). Stderr is shown.
#       other       Non-blocking error; first stderr line surfaces in the
#                   transcript.
#     We always exit 0 and keep stdout/stderr empty (subprocess output is
#     redirected to /dev/null). The script never blocks Claude Code.
#
#   - Async behaviour: Claude Code waits synchronously for the hook to
#     exit (default timeout 600 s). We return promptly after detaching
#     the audio worker via `setsid -f`, so the wait is effectively zero.
#
# Env vars:
#   CLAUDE_NOTIFY_DEBUG=1   Append every payload to dump.jsonl under STATE_DIR.
#                           Default off — full JSON dump can be large.
#                           spoken.log is unconditional (see file layout below).
#   CLAUDE_NOTIFY_NESTED=1  Internal recursion guard. Set by speak_summary
#                           when it spawns `claude -p`; the re-entered hook
#                           returns immediately (see "Recursion guard"
#                           below). Users should never set this manually.
#   XDG_STATE_HOME          Base for STATE_DIR; falls back to ~/.local/state.
#   XDG_RUNTIME_DIR         Base for RUNTIME_DIR; falls back to /tmp/<prog>-<uid>.
#   LC_ALL                  Forced to C.UTF-8 internally so ${#var} character
#                           counts work in the Stop branch (any caller-set
#                           value is overridden).
#
# File layout (split by scope and XDG category; <prog> = basename($0)):
#
#   /tmp/<prog>.voicevox.lock          — system-wide flock targets (mode 0666),
#   /tmp/<prog>.haiku.lock               shared across all UIDs.
#                                        voicevox_paplay itself runs fine in
#                                        parallel — audio just overlaps. The
#                                        serialization here is a UX
#                                        requirement of THIS script:
#                                        notifications from any concurrent
#                                        Claude Code session must NOT stomp
#                                        on each other. Haiku invocations are
#                                        also serialized because parallel
#                                        claude -p calls contend internally.
#
#   $XDG_RUNTIME_DIR/<prog>/                       — per-user RUNTIME_DIR
#       (fallback: /tmp/<prog>-<uid>, mode 0700)
#       spoke-recently-<session_id>    marker: idle_prompt is silenced for
#                                      ~90 s after Stop / permission_prompt
#       subagent-start-<session_id>    marker: SubagentStart suppressed for
#                                      ~30 s after the previous one
#
#   $XDG_STATE_HOME/<prog>/                        — per-user STATE_DIR
#       (fallback: $HOME/.local/state/<prog>)
#       dump.jsonl                     debug log: every payload as JSONL,
#                                      written only when CLAUDE_NOTIFY_DEBUG=1
#       spoken.log                     always-on, fixed-width log of every
#                                      utterance. Columns are space-padded
#                                      so they don't shift between events:
#                                        ISO_TS EVENT(14) sid=UUID haiku=STATUS(13) dur=Nms(11) MESSAGE
#                                      STATUS ∈ {OK, EMPTY, TIMEOUT, SKIPPED};
#                                      SKIPPED means no Haiku call was made
#                                      (cached / fixed-phrase paths). Grep
#                                      TIMEOUT to spot Haiku slowdowns at a
#                                      glance.
#
#   $XDG_CACHE_HOME/voicevox_paplay/               (managed by voicevox_paplay,
#       (fallback: $HOME/.cache/voicevox_paplay)    not by this script)
#       <text>_<hash>.wav              cached synthesis of fixed phrases
#
# All <prog>-suffixed paths use basename($0), so renaming the script renames
# its directories and locks. The binary's installation location
# (/usr/local/bin, /usr/bin, ~/.local/bin, ...) does not affect any of
# these paths.
#
# Internal-subagent heuristic:
#   The official docs (as of 2026-04-30) do not document Claude Code's
#   own background subagents (auto-dream / memory consolidation). We
#   filter them out by `agent_type == ""`, which is observation-based;
#   see is_internal_subagent() for the caveat.

set -u

# Force UTF-8 locale so ${#var} counts characters (not bytes) — affects the
# Haiku-skip threshold in the Stop branch.
export LC_ALL=C.UTF-8

# ---------------------------------------------------------------------------
# Tunables (exported so detached subshells inherit them)
# ---------------------------------------------------------------------------
# User-tunable voice options. Add --style-id / --pitch / --intonation here
# when adjusting the voice. Note: --loopback is intentionally NOT here — it
# is an implementation detail (audio routing) wired into each
# voicevox_paplay call site so it cannot be accidentally removed.
export VVOX_OPTS="--speed 1.2"
# Hard caps on subprocess durations (seconds).
export VVOX_TIMEOUT=30
# 60s chosen empirically: claude -p with --effort low on claude-haiku-4-5
# regressed to 18-64s after Claude Code 2.1.140 (was 21s on 2.1.139).
# 60s catches most successful calls while keeping the fallback path latency
# bounded. Timeouts are visible in spoken.log as `haiku=TIMEOUT`.
export HAIKU_TIMEOUT=60
# Haiku model used for Stop / SubagentStop summarization and CLI `say`
# katakana conversion.
export HAIKU_MODEL="claude-haiku-4-5"
# Haiku system prompt — single source of truth for the katakana-conversion
# persona used by every claude -p call this script makes. Both Stop
# summarization and CLI say share it; only the user prompt differs.
export HAIKU_SYSTEM_PROMPT="あなたは日本語のテキスト整形 AI です。出力にアルファベット表記を残さず、意訳せず発音をそのままカタカナにしてください。カタカナの間に中黒「・」は入れないでください。例: voicevox_paplay → ヴォイスボックスピーエープレイ、VVOX_LOCK → ブイヴォックスロック、ConfigChange → コンフィグチェンジ。"

# Hook events accepted by the dispatcher; also surfaced via the `events` CLI.
# Listed explicitly (rather than derived from EVENT_PHRASES keys) so the
# output order is stable and predictable.
HOOK_EVENTS=(
  Stop
  Notification
  SubagentStart
  SubagentStop
  ConfigChange
  PreCompact
  WorktreeCreate
  CwdChanged
)

# Per-event default / fallback phrase. Single source of truth shared by the
# runtime handlers (used as the cached fixed phrase or the Haiku fallback)
# and the `say <EVENT>` CLI shortcut. Notification is multi-modal (idle vs
# permission); the idle phrase is the default representative entry here,
# while the permission-prompt sub-phrases live next to that branch's
# matcher logic where they belong.
declare -A EVENT_PHRASES=(
  [Stop]="ご返答をお願いします。"
  [Notification]="作業が終わりました。"
  [SubagentStart]="サブエージェントを起動しています。"
  [SubagentStop]="サブエージェントから戻りました。"
  [ConfigChange]="設定をリロードしたよ。"
  [PreCompact]="コンテキストを圧縮します。"
  [WorktreeCreate]="ワークツリーを作成します。"
  [CwdChanged]="作業ディレクトリが変わりました。"
)

# Derive the program name from $0 so renaming the script also moves its
# state directories accordingly.
PROG_NAME="$(basename "$0")"

# Persistent state (debug logs only). XDG_STATE_HOME is the canonical home
# for "state that should persist across sessions" per the XDG Base Dir spec
# (https://specifications.freedesktop.org/basedir-spec/).
if [ -n "${XDG_STATE_HOME:-}" ]; then
  STATE_DIR="${XDG_STATE_HOME%/}/$PROG_NAME"
else
  STATE_DIR="$HOME/.local/state/$PROG_NAME"
fi

# Per-user ephemeral runtime dir for session markers. XDG_RUNTIME_DIR is
# wiped at logout and is mode 0700 per spec, ideal for short-lived per-user
# state. Falls back to a uid-suffixed /tmp dir on systems without XDG_RUNTIME_DIR
# (e.g. minimal containers); we chmod 0700 below to match the spec's privacy.
if [ -n "${XDG_RUNTIME_DIR:-}" ]; then
  RUNTIME_DIR="${XDG_RUNTIME_DIR%/}/$PROG_NAME"
else
  RUNTIME_DIR="/tmp/$PROG_NAME-$(id -u)"
fi

# System-wide flock targets, kept in /tmp (universally writable) with mode
# 0666 so any UID can take them. The two locks have different semantics:
#
#   voicevox.lock  — voicevox_paplay itself is fine running in parallel
#                    (audio just overlaps). Serializing it here is a UX
#                    choice for THIS script: notifications from concurrent
#                    Claude Code sessions must not stomp on each other.
#                    Taken unconditionally in hook mode; CLI takes it only
#                    when invoked with --serialize.
#   haiku.lock     — taken unconditionally whenever speak_summary runs a
#                    `claude -p` call. Parallel claude -p invocations
#                    contend internally (observed: 3 simultaneous fires
#                    produced one 15 s timeout), so without this lock the
#                    summarizer breaks. The CLI never reaches this lock
#                    because the CLI path doesn't invoke claude.
VVOX_LOCK="/tmp/$PROG_NAME.voicevox.lock"
# Exported so haiku_katakanize_sync can flock it from a setsid -f subshell
# (the hook path) without having to thread it through positional args.
export HAIKU_LOCK="/tmp/$PROG_NAME.haiku.lock"

# spoken.log is always written — it's a small TSV (~100 B per utterance) and
# the timing/status columns are the user-facing diagnostic surface for Haiku
# timeouts. dump.jsonl stays opt-in because the full hook payload is large.
SPOKEN_LOG="$STATE_DIR/spoken.log"
if [ "${CLAUDE_NOTIFY_DEBUG:-0}" = "1" ]; then
  DUMP_LOG="$STATE_DIR/dump.jsonl"
else
  DUMP_LOG=""
fi

# Ensure each system-wide lock file exists with mode 0666 so any UID can take
# flock on it. The umask=0 subshell overrides the caller's typical 0022 mask
# so the new file is mode 0666 (open(O_CREAT) is atomic, so a parallel race
# resolves to a single inode).
ensure_lock() {
  [ -e "$1" ] || ( umask 0; : > "$1" ) 2>/dev/null
}

# True when text contains an English word — defined as a run of 3+ ASCII
# letters, regardless of case. 1-2 letter tokens (A, PR, AI, OS) stay
# direct because VOICEVOX reads them letter-by-letter ("エー", "ピーアール")
# the way Japanese listeners expect. 3+ letter runs go to Haiku even when
# all-uppercase (PUSH, GIT) — users sometimes shout shell verbs in caps,
# and "ピー・ユー・エス・エイチ" beats letter-by-letter readout in neither
# direction.
contains_english_word() {
  printf '%s' "$1" | LC_ALL=C grep -qE '[A-Za-z]{3,}'
}

# True if hook fires from a Claude Code background session
# (`claude agents --json` の .kind 判定)。 idle_prompt 抑止用、
# 失敗時 false (= 発話する側へ safe fall through)。
is_background_session() {
  [ -n "${SESSION_ID:-}" ] && [ "$SESSION_ID" != "unknown" ] || return 1
  local kind
  kind=$(CLAUDE_NOTIFY_NESTED=1 timeout 5 claude agents --json 2>/dev/null \
    | jq -r --arg sid "$SESSION_ID" \
        '.[]? | select(.sessionId == $sid) | .kind // empty' 2>/dev/null \
    | head -1)
  [ "$kind" = "background" ]
}

# Synchronously invoke Haiku to katakana-ize the given user prompt and emit
# the resulting single-line text on stdout (empty on failure). Caller chooses
# foreground (CLI say) vs detached (hook path wraps this in setsid -f inside
# speak_summary). Exported so it is visible inside `bash -c '...'` subshells.
haiku_katakanize_sync() {
  # --setting-sources "" loads no settings file at all (the empty
  # string is accepted by claude as "skip every source", verified
  # empirically). Earlier we used `cd /tmp && --setting-sources local`
  # to land in a directory without a .claude/ tree — this is the
  # cleaner equivalent. User-level SessionStart hooks don't fire on
  # this short-lived child, the user's effortLevel doesn't leak in,
  # and OAuth/keychain auth keeps working (unlike --bare).
  # --effort low: a single-line katakana / 30-char summarize task
  # doesn't benefit from a higher effort tier and pays a real latency
  # cost. Long input + low effort still produces correct summaries —
  # measured ~14 s for a ~1.1 KB SubagentStop message.
  CLAUDE_NOTIFY_NESTED=1 \
    flock "$HAIKU_LOCK" timeout "$HAIKU_TIMEOUT" claude \
    --model "$HAIKU_MODEL" \
    --effort low \
    --setting-sources "" \
    --no-session-persistence \
    --disable-slash-commands \
    --tools "" \
    --strict-mcp-config \
    --system-prompt "$HAIKU_SYSTEM_PROMPT" \
    -p "$1" 2>/dev/null \
    | tr -d "\r\n"
}
export -f haiku_katakanize_sync

# CLI flag: --serialize makes the `say` subcommand take VVOX_LOCK so the CLI
# utterance won't overlap with concurrent hook-driven ones. Hook mode takes
# VVOX_LOCK unconditionally (wired into the speak_* helpers below), so this
# flag only has effect on the CLI path. HAIKU_LOCK is taken whenever any
# claude -p call runs — Stop summarization, or CLI say with English-word text.
SERIALIZE=0
if [ "${1:-}" = "--serialize" ]; then
  SERIALIZE=1
  shift
fi

# ---------------------------------------------------------------------------
# CLI subcommands (handled before stdin is touched, so they don't block).
# ---------------------------------------------------------------------------
usage() {
  cat <<EOF
Usage: $PROG_NAME [--serialize] SUBCOMMAND   # interactive CLI use
       $PROG_NAME [EVENT_NAME]               # hook mode (for Claude Code, JSON on stdin)

Options (CLI mode only):
  --serialize      Acquire VVOX_LOCK before speaking so this CLI utterance
                   does not overlap with concurrent hook-driven ones. Only
                   meaningful with \`say\`; hook mode serializes implicitly.

Subcommands:
  events           List the hook events this script understands.
  log [N]          Show the last N (default 20) spoken-log entries.
  say TEXT         Speak TEXT in the configured voice. If TEXT happens to
                   be one of the supported event names (Stop, Notification,
                   SubagentStart, ...), plays that event's characteristic
                   phrase instead — useful for previewing notifications.
  help             Show this help.

Hook mode:
  Claude Code runs this script via settings.json's hooks block. The JSON
  payload arrives on stdin; the event name is taken from argv[1] (set in
  the configured command) or the payload's hook_event_name field. Any
  argv that is not a subcommand falls through to this mode, so a stray
  CLI invocation like '$PROG_NAME Stop' from a terminal is rejected with
  a usage hint instead of hanging on stdin. Always exits 0; no stdout.

Environment Variables:
  CLAUDE_NOTIFY_DEBUG=1   Append every payload to dump.jsonl under STATE_DIR.
                          spoken.log is always written (see Locations).

Locations:
  Debug logs (per-user, opt-in):  $STATE_DIR
  Session markers (per-user):     $RUNTIME_DIR
  Voicevox flock (system-wide):   $VVOX_LOCK
  Haiku flock (system-wide):      $HAIKU_LOCK

Examples:
  $PROG_NAME say "進めますか"               # speak arbitrary text
  $PROG_NAME say Stop                       # preview the Stop event's audio
  $PROG_NAME --serialize say Stop           # same, queued behind any active hook
  $PROG_NAME log 50                         # tail the last 50 utterances
  $PROG_NAME events                         # list supported hook events
EOF
}

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
  events|--list-events)
    printf '%s\n' "${HOOK_EVENTS[@]}"
    exit 0
    ;;
  log|--show-log)
    LOG_PATH="$STATE_DIR/spoken.log"
    if [ ! -f "$LOG_PATH" ]; then
      echo "$PROG_NAME: no spoken log at $LOG_PATH" >&2
      echo "Trigger a hook event to create it (the file is created on first write)." >&2
      exit 1
    fi
    tail -n "${2:-20}" "$LOG_PATH"
    exit 0
    ;;
  say|--say)
    if [ -z "${2:-}" ]; then
      echo "Usage: $PROG_NAME [--serialize] say TEXT|EVENT_NAME" >&2
      exit 2
    fi
    # If $2 names a hook event, speak its characteristic phrase (same
    # text the runtime handler would use). Otherwise treat $2 as raw text.
    text="${EVENT_PHRASES[$2]:-$2}"
    # English word in the text (push, git, ...) → route through Haiku
    # synchronously so VOICEVOX gets katakana instead of bare ASCII (which
    # it would otherwise read out letter by letter). CLI is interactive,
    # so we block here; hook path detaches the equivalent call via setsid.
    if contains_english_word "$text"; then
      ensure_lock "$HAIKU_LOCK"
      converted=$(haiku_katakanize_sync "次の一文をそのままカタカナ化して返してください。意味・長さ・語順は変えないでください。出力は変換後の一文のみ。装飾・引用符・改行・前置きなし。

文:
$text")
      [ -n "$converted" ] && text=$converted
    fi
    if [ "$SERIALIZE" = "1" ]; then
      ensure_lock "$VVOX_LOCK"
      exec flock "$VVOX_LOCK" voicevox_paplay --loopback $VVOX_OPTS "$text"
    else
      exec voicevox_paplay --loopback $VVOX_OPTS "$text"
    fi
    ;;
esac

# Past this point we are in hook mode. If stdin is a terminal the user is
# probably running us by mistake — show usage instead of blocking on `cat`.
if [ -t 0 ]; then
  echo "$PROG_NAME: hook mode requires JSON on stdin." >&2
  echo "Run '$PROG_NAME help' for the CLI subcommands." >&2
  exit 2
fi

# Recursion guard. speak_summary spawns `claude -p` for Haiku; that claude
# session fires its own Stop / Notification etc. hooks when it exits, which
# would re-enter this script and produce duplicate utterances (or, worse,
# kick off a second Haiku call to summarize the first summary). The marker
# is set inline on the claude invocation in speak_summary, so it propagates
# only down that subtree — interactive sessions never inherit it.
[ -n "${CLAUDE_NOTIFY_NESTED:-}" ] && exit 0

# ---------------------------------------------------------------------------
# Hook mode
# ---------------------------------------------------------------------------
mkdir -p "$RUNTIME_DIR" "$STATE_DIR"
chmod 0700 "$RUNTIME_DIR" 2>/dev/null

ensure_lock "$VVOX_LOCK"
ensure_lock "$HAIKU_LOCK"

# Stale per-session markers accumulate when XDG_RUNTIME_DIR is persistent
# (e.g. some non-systemd setups). 1h is well past any meaningful suppression
# window (idle = 90s, subagent inhibition = 30s).
find "$RUNTIME_DIR" -type f \( -name 'spoke-recently-*' -o -name 'subagent-start-*' -o -name 'cwd-changed-*' \) \
  -mmin +60 -delete 2>/dev/null

INPUT="$(cat)"

# Bail out silently on a malformed payload. Doing this once up-front means
# every subsequent jq invocation can assume valid JSON (no need to scatter
# `2>/dev/null` across every read), and any parse error never reaches the
# transcript Claude Code captures from stderr.
printf '%s' "$INPUT" | jq -e . >/dev/null 2>&1 || exit 0

NOW="$(date +%s)"
TS="$(date -Iseconds)"
SESSION_ID="$(printf '%s' "$INPUT" | jq -r '.session_id // empty')"
SESSION_ID="${SESSION_ID:-unknown}"

# Event name: prefer argv (legacy / explicit), else fall back to stdin's
# hook_event_name field so a single settings.json command can serve every
# hook entry. Empty result → silently exit (nothing to dispatch).
EVENT="${1:-}"
[ -n "$EVENT" ] || EVENT=$(printf '%s' "$INPUT" | jq -r '.hook_event_name // empty')
[ -n "$EVENT" ] || exit 0

if [ -n "$DUMP_LOG" ]; then
  jq -cn --arg event "$EVENT" --arg ts "$TS" --argjson payload "$INPUT" \
    '{event: $event, ts: $ts, payload: $payload}' >> "$DUMP_LOG"
fi

SPOKE_MARKER="$RUNTIME_DIR/spoke-recently-$SESSION_ID"
SUBAGENT_MARKER="$RUNTIME_DIR/subagent-start-$SESSION_ID"
CWD_MARKER="$RUNTIME_DIR/cwd-changed-$SESSION_ID"

# All three speak_* helpers detach via `setsid -f` (the parent script
# returns to Claude Code immediately) and serialize voicevox playback
# through VVOX_LOCK so utterances never overlap. They differ only in what
# they ultimately voice:
#
#   speak_cached(text)         fixed phrase via voicevox_paplay --cache
#                              (cache is at $XDG_CACHE_HOME/voicevox_paplay)
#   speak_text(text)           arbitrary text, no cache
#   speak_summary(prompt, fb)  Haiku summarizes prompt under HAIKU_LOCK,
#                              falling back to fb on timeout / parse failure
speak_cached() {
  local text="$1"
  setsid -f bash -c '
    text=$1
    vvox_lock=$2
    event=$3
    log=$4
    sid=$5
    printf "%s %-14s sid=%s %-13s %-11s %s\n" "$(date -Iseconds)" "$event" "$sid" "haiku=SKIPPED" "dur=N/A" "$text" >> "$log"
    flock "$vvox_lock" timeout "$VVOX_TIMEOUT" voicevox_paplay --loopback $VVOX_OPTS --cache "$text"
  ' _ "$text" "$VVOX_LOCK" "$EVENT" "$SPOKEN_LOG" "$SESSION_ID" </dev/null >/dev/null 2>&1
}

speak_text() {
  local text="$1"
  setsid -f bash -c '
    text=$1
    vvox_lock=$2
    event=$3
    log=$4
    sid=$5
    printf "%s %-14s sid=%s %-13s %-11s %s\n" "$(date -Iseconds)" "$event" "$sid" "haiku=SKIPPED" "dur=N/A" "$text" >> "$log"
    flock "$vvox_lock" timeout "$VVOX_TIMEOUT" voicevox_paplay --loopback $VVOX_OPTS "$text"
  ' _ "$text" "$VVOX_LOCK" "$EVENT" "$SPOKEN_LOG" "$SESSION_ID" </dev/null >/dev/null 2>&1
}

speak_summary() {
  local prompt="$1"
  local fallback="$2"
  setsid -f bash -c '
    prompt=$1
    fallback=$2
    vvox_lock=$3
    event=$4
    log=$5
    haiku_timeout=$6
    sid=$7
    # $EPOCHREALTIME → "1736000000.123456"; strip the dot to get microseconds
    # (bash 5+). Integer math avoids awk/bc and stays accurate to 1ms.
    start_us=${EPOCHREALTIME/./}
    summary=$(haiku_katakanize_sync "$prompt")
    end_us=${EPOCHREALTIME/./}
    dur_ms=$(( (end_us - start_us) / 1000 ))
    if [ -z "$summary" ]; then
      # Heuristic: a timeout(1) SIGKILL terminates claude near
      # haiku_timeout seconds. Anything ≥95% of the budget with empty
      # output is almost certainly the timeout; below that it is some
      # other empty-output failure (auth, network, parse).
      if [ "$dur_ms" -ge $(( haiku_timeout * 950 )) ]; then
        status=TIMEOUT
      else
        status=EMPTY
      fi
      summary=$fallback
    else
      status=OK
    fi
    # Safety cap: the prompt asks for ≤30 chars but Haiku occasionally
    # overshoots; allow up to 40 then chop. Bash substring is character-
    # aware (not byte-based) under LC_ALL=C.UTF-8, so this never splits
    # a multi-byte sequence mid-codepoint.
    summary=${summary:0:40}
    printf "%s %-14s sid=%s %-13s %-11s %s\n" "$(date -Iseconds)" "$event" "$sid" "haiku=$status" "dur=${dur_ms}ms" "$summary" >> "$log"
    flock "$vvox_lock" timeout "$VVOX_TIMEOUT" voicevox_paplay --loopback $VVOX_OPTS "$summary"
  ' _ "$prompt" "$fallback" "$VVOX_LOCK" "$EVENT" "$SPOKEN_LOG" "$HAIKU_TIMEOUT" "$SESSION_ID" </dev/null >/dev/null 2>&1
}

# CwdChanged: cwd を「作業ディレクトリが変わりました。」+ スラッシュ区切りカタカナ読みで発話。 path→読みを cache し再訪で Haiku を省く。
speak_cwd() {
  local cwd="$1"
  setsid -f bash -c '
    cwd=$1
    vvox_lock=$2
    log=$3
    sid=$4
    fallback=$5
    cache_dir=$6
    mkdir -p "$cache_dir"
    # path 内容ハッシュで読みを cache。 Haiku 出力は非決定的なので読みを固定し、 合成 --cache も効かせる。
    key=$(cksum <<<"$cwd"); key=${key%% *}
    cache_file="$cache_dir/$key"
    if [ -s "$cache_file" ]; then
      reading=$(<"$cache_file"); status=CACHED
    else
      reading=$(haiku_katakanize_sync "次は変更後の作業ディレクトリの絶対パスです。音声読み上げ用に、文頭へ「作業ディレクトリが変わりました。」を付け、続けてパスを、区切りの / は「スラッシュ」と読み、各階層名のアルファベットは発音どおりのカタカナにして、空白区切りの一文で返してください。出力は一文のみ。装飾・引用符・改行・前置きなし。
パス:
$cwd")
      if [ -n "$reading" ]; then
        printf "%s" "$reading" >"$cache_file"; status=OK
      else
        reading=$fallback; status=EMPTY
      fi
    fi
    reading=${reading:0:200}
    printf "%s %-14s sid=%s %-13s %-11s %s\n" "$(date -Iseconds)" "CwdChanged" "$sid" "haiku=$status" "dur=N/A" "$reading" >> "$log"
    flock "$vvox_lock" timeout "$VVOX_TIMEOUT" voicevox_paplay --loopback $VVOX_OPTS --cache "$reading"
  ' _ "$cwd" "$VVOX_LOCK" "$SPOKEN_LOG" "$SESSION_ID" "${EVENT_PHRASES[CwdChanged]}" "$STATE_DIR/cwd-readings" </dev/null >/dev/null 2>&1
}

age_of() {
  local f="$1"
  if [ ! -f "$f" ]; then
    # Sentinel: never observed → infinitely old, so any age comparison passes.
    echo 999999
    return
  fi
  echo $(( NOW - $(stat -c %Y "$f") ))
}

# Distinguish user-spawned subagents from Claude Code's internal ones
# (auto-dream etc.). Heuristic from observed payloads (Claude Code 2.1.123,
# 2026-04-30):
#   - User-spawned: agent_type="general-purpose" 等、Start/Stop の対で発火
#   - Internal:     agent_type=""、SubagentStop のみ発火（Start は来ない）
# 仕様は API 安定保証なし。動作変化を見つけたら dump.jsonl の payload 構造を再確認。
is_internal_subagent() {
  local at
  at=$(printf '%s' "$INPUT" | jq -r '.agent_type // ""' 2>/dev/null)
  [ -z "$at" ]
}

# True when last_assistant_message ends in `？` or `?` (heuristic for "the
# user is being asked something at the end of this turn").
detect_question() {
  printf '%s' "$INPUT" \
    | jq -r '.last_assistant_message // ""' \
    | sed 's/[[:space:]]*$//' \
    | awk 'NF{l=$0} END{print l}' \
    | grep -qE '[？?]$'
}

case "$EVENT" in
  Stop)
    is_background_session && exit 0  # bg は user 待ち状態でないので silent
    if detect_question; then
      # Anchor on the same "last non-empty line" detect_question used, then
      # extract the last sentence within it. Earlier we flattened the whole
      # message with `tr '\n' ' '` and ran the sentence regex over that —
      # but in list-formatted answers the period after "1.", "2." gets
      # treated as a sentence delimiter, so the trailing question gets
      # prefixed with the last list item (e.g. "あれ  どれにしますか？").
      LAST_LINE=$(printf '%s' "$INPUT" | jq -r '.last_assistant_message // ""' \
        | sed 's/[[:space:]]*$//' | awk 'NF{l=$0} END{print l}')
      LAST_SENTENCE=$(printf '%s' "$LAST_LINE" \
        | grep -oE '[^。？?]*[。？?]' | tail -1 | sed 's/^[[:space:]]*//')
      [ -z "$LAST_SENTENCE" ] && LAST_SENTENCE="$LAST_LINE"
      # Already ≤30 chars AND no English word: skip the ~6s Haiku cold-start
      # and speak as-is. See contains_english_word for the exact definition
      # (3+ consecutive ASCII letters, regardless of case).
      if [ "${#LAST_SENTENCE}" -le 30 ] && ! contains_english_word "$LAST_SENTENCE"; then
        speak_text "$LAST_SENTENCE"
      else
        speak_summary "次の一文を 30 文字以下の自然な日本語に整えてください。意図と意味は変えないこと。アルファベットの単語・略語はそのまま残さず、すべて発音通りのカタカナに置き換えてください (例: commit → コミット、OK → オーケー、push → プッシュ)。
出力は整えた一文のみ。装飾・引用符・改行・前置きなし。

文:
$LAST_SENTENCE" "${EVENT_PHRASES[Stop]}"
      fi
      touch "$SPOKE_MARKER"
    fi
    ;;
  Notification)
    NOTIF_TYPE=$(printf '%s' "$INPUT" | jq -r '.notification_type // ""')
    case "$NOTIF_TYPE" in
      idle_prompt)
        if [ "$(age_of "$SPOKE_MARKER")" -ge 90 ]; then
          is_background_session && exit 0  # bg session の idle 連発抑止
          speak_cached "${EVENT_PHRASES[Notification]}"
        fi
        ;;
      permission_prompt)
        is_background_session && exit 0  # bg session は user attention 設計外なので silent
        # attention (AskUserQuestion 等) と permission (Bash 等の許可) を統一発話。
        # 未知パターンは silent (誤発話より沈黙)。
        NOTIF_MSG=$(printf '%s' "$INPUT" | jq -r '.message // ""')
        case "$NOTIF_MSG" in
          *"needs your attention"*|*"needs your permission"*)
            speak_cached "お伺いしたいことがあります。"
            touch "$SPOKE_MARKER"
            ;;
        esac
        ;;
    esac
    ;;
  SubagentStart)
    is_internal_subagent && exit 0
    if [ "$(age_of "$SUBAGENT_MARKER")" -ge 30 ]; then
      speak_cached "${EVENT_PHRASES[SubagentStart]}"
      touch "$SUBAGENT_MARKER"
    fi
    ;;
  SubagentStop)
    is_internal_subagent && exit 0
    LAST_MSG=$(printf '%s' "$INPUT" | jq -r '.last_assistant_message // ""')
    speak_summary "以下は AI サブエージェントが最後に出力したテキストです。
このサブエージェントが何を完了・報告したかを、30 文字以下の自然な日本語で簡潔にまとめてください。アルファベットの単語・略語はそのまま残さず、すべて発音通りのカタカナに置き換えてください (例: commit → コミット、PR → ピーアール、push → プッシュ)。
出力は要約のみ。装飾・引用符・改行・前置きなし。

応答:
$LAST_MSG" "${EVENT_PHRASES[SubagentStop]}"
    ;;
  ConfigChange)
    is_background_session && exit 0  # 全 session が ack するので bg は silent (多重発話抑止)
    # source field (公式 hooks reference で確認) で設定種別ごとに文言を分岐。 未知 source は既定句。
    case "$(printf '%s' "$INPUT" | jq -r '.source // ""')" in
      user_settings)    speak_cached "ユーザー設定を変更したよ。" ;;
      project_settings) speak_cached "プロジェクト設定を変更したよ。" ;;
      local_settings)   speak_cached "ローカル設定を変更したよ。" ;;
      policy_settings)  speak_cached "ポリシー設定を変更したよ。" ;;
      skills)           speak_cached "スキルを変更したよ。" ;;
      *)                speak_cached "${EVENT_PHRASES[ConfigChange]}" ;;
    esac
    ;;
  PreCompact)
    # bg は発話を短縮 (UUID 読み上げが冗長になるため)、 sessionId は spoken.log の
    # sid 列で照合する。
    if is_background_session; then
      speak_cached "バックグラウンドセッションの圧縮を開始します。セッションIDをログを参照してください。"
    else
      speak_cached "${EVENT_PHRASES[PreCompact]}"
    fi
    ;;
  WorktreeCreate)
    speak_cached "${EVENT_PHRASES[WorktreeCreate]}"
    ;;
  CwdChanged)
    is_background_session && exit 0  # bg は cwd 追従不要なので silent
    if [ "$(age_of "$CWD_MARKER")" -ge 30 ]; then  # cd 連発のノイズ抑止
      NEW_CWD=$(printf '%s' "$INPUT" | jq -r '.cwd // ""')
      if [ -n "$NEW_CWD" ]; then
        speak_cwd "$NEW_CWD"
        touch "$CWD_MARKER"
      fi
    fi
    ;;
esac

exit 0
