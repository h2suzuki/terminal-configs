#!/bin/bash
# claude-emergency-stop — single entry point for halting a runaway
# claude bg-session cascade.
#
# Invoked by the user (or this assistant) when bg sessions are
# multiplying. Each step's ordering and inclusion is justified below
# from the 2026-05-28 cascade investigation (originSessionId
# b188f677), not from intuition.
#
# Step ordering rationale (evidence-based):
#
#   step 1 (hook file mv to /tmp):
#     Decisive — the only step in the 2026-05-28 investigation that
#     observably stopped further worker generation (E6 in
#     `~/.claude/memory/.../feedback_setting_sources_does_not_disable_managed.md`).
#     File unreachable at the resolved path → worker spawn fails.
#   step 2 (clear roster.json):
#     Pairs with step 3 — supervisor restart adopts workers via
#     roster.json (`bg adopt: adopted=26 respawned=0 dead=0` in
#     daemon.log 2026-05-28T03:19:18). Without clearing, step 3 is
#     reversed on next on-demand daemon start.
#   step 3 (daemon stop):
#     Shuts down the supervisor. Subsequent `claude` invocations may
#     start a fresh transient daemon, but with empty roster (step 2)
#     and missing hooks (step 1) it cannot resume the cascade.
#   step 4 (stop existing bg sessions):
#     Existing workers do not auto-terminate when the hook file
#     disappears mid-run; they only stop spawning new children. This
#     step clears LLM-call cost from in-flight sessions.
#   step 5 (pkill voicevox orphans):
#     Side-effect cleanup. The cascade itself is stopped by steps
#     1–3; this step only reclaims audio device / lock resources
#     faster than waiting for natural process exit.
#
# Earlier draft ordering (stop / daemon / file mv / roster / cache /
# vvox) put the decisive step third — that mirrors the by-hand
# attempts in the 2026-05-28 cascade, which left ~7 turns of
# generation in flight before the file mv landed. The new ordering
# starts with the decisive cut.
#
# Removed from earlier draft: inflight / staging cache wipe. That
# cleanup is not part of stopping the cascade (dispatch triggers are
# already blocked by step 1) and belongs in a separate restoration
# helper if needed.
#
# Idempotent: each step tolerates missing files / no matching
# processes. Exit 0 on full clean stop, 1 if anything could not be
# halted.

set -u

LOG_PREFIX='claude-emergency-stop:'
QUARANTINE_DIR='/tmp'
ETC_HOOKS='/etc/claude-code/hooks'
SETTINGS_JSON='/etc/claude-code/settings.json'
DAEMON_DIR="${HOME}/.claude/daemon"

exit_code=0
note() { printf '%s %s\n' "$LOG_PREFIX" "$*"; }
warn() { printf '%s WARN: %s\n' "$LOG_PREFIX" "$*" >&2; exit_code=1; }

# Prerequisites — every step requires at least one of these.
for cmd in claude jq sudo; do
  command -v "$cmd" >/dev/null 2>&1 || { warn "missing $cmd, aborting"; exit 1; }
done

# step 1: physically disable every SessionStart hook script registered
# in the deployed settings.json by moving it to /tmp/<name>.disabled.
note 'step 1: disable SessionStart hook scripts (mv to /tmp)'
if [[ -r "$SETTINGS_JSON" ]]; then
  while IFS= read -r cmd; do
    [[ -z "$cmd" ]] && continue
    script="${cmd%% *}"
    [[ -z "$script" ]] && continue
    [[ "$script" != "$ETC_HOOKS"/* ]] && continue
    if [[ -e "$script" ]]; then
      base="${script##*/}"
      dest="$QUARANTINE_DIR/${base}.disabled"
      if sudo -n mv "$script" "$dest" >/dev/null 2>&1; then
        note "  moved: $script -> $dest"
      else
        warn "  could not mv $script (sudo -n failed?)"
      fi
    fi
  done < <(jq -r '.hooks.SessionStart // [] | .[] | .hooks // [] | .[] | .command' \
             "$SETTINGS_JSON" 2>/dev/null)
else
  warn '  settings.json unreadable, skipping hook mv'
fi

# step 2: clear daemon roster so a respawned daemon cannot re-adopt
# workers via `bg adopt`.
note 'step 2: clear daemon roster.json'
rm -f "$DAEMON_DIR/roster.json" 2>/dev/null || true

# step 3: shut down the supervisor daemon.
note 'step 3: stop supervisor daemon'
claude daemon stop --any </dev/null >/dev/null 2>&1 || true

# step 4: stop any bg session that survived steps 1-3.
note 'step 4: stop all bg sessions'
ids=$(claude agents --json 2>/dev/null \
        | jq -r '.[] | select(.kind=="background") | .sessionId' 2>/dev/null \
        || true)
count=$(printf '%s\n' "$ids" | grep -c . || true)
note "  bg sessions to stop: $count"
for id in $ids; do
  [[ -z "$id" ]] && continue
  claude stop "$id" </dev/null >/dev/null 2>&1 || warn "  could not stop $id"
done

# step 5: pkill orphan voicevox processes (side-effect cleanup).
note 'step 5: pkill voicevox orphans'
pkill -f 'voicevox_paplay'        >/dev/null 2>&1 || true
pkill -f 'voicevox_claude_alerts' >/dev/null 2>&1 || true

# Final state report — direct observation, no inference.
note '--- final state ---'
remaining=$(claude agents --json 2>/dev/null \
              | jq '[.[] | select(.kind=="background")] | length' 2>/dev/null \
              || echo '?')
note "  bg sessions remaining: $remaining"
daemon_state=$(claude daemon status 2>&1 | head -1 || echo '?')
note "  daemon: $daemon_state"

exit "$exit_code"
